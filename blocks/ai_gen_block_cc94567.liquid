{% assign ai_gen_id = block.id | replace: '_', '' | downcase %}

{% style %}
  .ai-breadcrumb-{{ ai_gen_id }} {
    display: block;
    width: 100%;
    padding: {{ block.settings.padding_top }}px 0 {{ block.settings.padding_bottom }}px;
  }

  .ai-breadcrumb-container-{{ ai_gen_id }} {
    margin: 0 auto;
    padding: 0 20px;
  }

  .ai-breadcrumb-nav-{{ ai_gen_id }} {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
    font-size: {{ block.settings.font_size }}px;
    color: {{ block.settings.text_color }};
  }

  .ai-breadcrumb-item-{{ ai_gen_id }} {
    display: flex;
    align-items: center;
    gap: {{ block.settings.spacing }}px;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }} {
    color: {{ block.settings.link_color }};
    text-decoration: none;
    transition: color 0.2s ease;
  }

  .ai-breadcrumb-link-{{ ai_gen_id }}:hover {
    color: {{ block.settings.link_hover_color }};
  }

  .ai-breadcrumb-current-{{ ai_gen_id }} {
    color: {{ block.settings.current_color }};
  }

  .ai-breadcrumb-separator-{{ ai_gen_id }} {
    color: {{ block.settings.separator_color }};
    user-select: none;
  }

  @media screen and (max-width: 749px) {
    .ai-breadcrumb-{{ ai_gen_id }} {
      padding: {{ block.settings.padding_top | times: 0.7 }}px 0 {{ block.settings.padding_bottom | times: 0.7 }}px;
    }

    .ai-breadcrumb-nav-{{ ai_gen_id }} {
      font-size: {{ block.settings.font_size | times: 0.9 }}px;
    }
  }
{% endstyle %}

<breadcrumb-navigation-{{ ai_gen_id }} class="container ai-breadcrumb-{{ ai_gen_id }}" {{ block.shopify_attributes }}>
  <div class="ai-breadcrumb-container-{{ ai_gen_id }}">
    <nav class="ai-breadcrumb-nav-{{ ai_gen_id }}" aria-label="Breadcrumb">
      <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
        <a href="/" class="breadcrumbs-list__link ai-breadcrumb-link-{{ ai_gen_id }}">{{ block.settings.home_text }}</a>
        <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
      </div>

      {% if collection %}
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ collection.title }}</span>
        </div>
      {% elsif product %}
        {% if collection %}
          <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <a href="{{ collection.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ collection.title }}</a>
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
          </div>
        {% elsif product.collections.size > 0 %}
          <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
            <a href="{{ product.collections.first.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ product.collections.first.title }}</a>
            <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
          </div>
        {% endif %}
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ product.title }}</span>
        </div>
      {% elsif page %}
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ page.title }}</span>
        </div>
      {% elsif blog %}
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ blog.title }}</span>
        </div>
      {% elsif article %}
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <a href="{{ blog.url }}" class="ai-breadcrumb-link-{{ ai_gen_id }}">{{ blog.title }}</a>
          <span class="ai-breadcrumb-separator-{{ ai_gen_id }}" aria-hidden="true">{{ block.settings.separator }}</span>
        </div>
        <div class="ai-breadcrumb-item-{{ ai_gen_id }}">
          <span class="ai-breadcrumb-current-{{ ai_gen_id }}" aria-current="page">{{ article.title }}</span>
        </div>
      {% endif %}
    </nav>
  </div>
</breadcrumb-navigation-{{ ai_gen_id }}>

<script>
  (function() {
    class BreadcrumbNavigation{{ ai_gen_id }} extends HTMLElement {
      constructor() {
        super();
      }
    }

    customElements.define('breadcrumb-navigation-{{ ai_gen_id }}', BreadcrumbNavigation{{ ai_gen_id }});
  })();
</script>

{% schema %}
{
  "name": "Collection breadcrumb",
  "tag": null,
  "settings": [
    {
      "type": "header",
      "content": "Content"
    },
    {
      "type": "text",
      "id": "home_text",
      "label": "Home text",
      "default": "Home"
    },
    {
      "type": "text",
      "id": "separator",
      "label": "Separator",
      "default": "/"
    },
    {
      "type": "header",
      "content": "Style"
    },
    {
      "type": "range",
      "id": "font_size",
      "min": 12,
      "max": 24,
      "step": 1,
      "unit": "px",
      "label": "Font size",
      "default": 14
    },
    {
      "type": "range",
      "id": "spacing",
      "min": 4,
      "max": 20,
      "step": 2,
      "unit": "px",
      "label": "Spacing",
      "default": 8
    },
    {
      "type": "color",
      "id": "text_color",
      "label": "Text color",
      "default": "#232323"
    },
    {
      "type": "color",
      "id": "link_color",
      "label": "Link color",
      "default": "#bf570a"
    },
    {
      "type": "color",
      "id": "link_hover_color",
      "label": "Link hover color",
      "default": "#5c5c5c"
    },
    {
      "type": "color",
      "id": "current_color",
      "label": "Current page color",
      "default": "#232323"
    },
    {
      "type": "color",
      "id": "separator_color",
      "label": "Separator color",
      "default": "#5c5c5c"
    },
    {
      "type": "header",
      "content": "Layout"
    },
    {
      "type": "range",
      "id": "padding_top",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding top",
      "default": 20
    },
    {
      "type": "range",
      "id": "padding_bottom",
      "min": 0,
      "max": 60,
      "step": 4,
      "unit": "px",
      "label": "Padding bottom",
      "default": 20
    }
  ],
  "presets": [
    {
      "name": "Collection breadcrumb"
    }
  ]
}
{% endschema %}
