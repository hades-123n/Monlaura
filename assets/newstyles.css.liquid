.swatch-as-pic, .swatch-as-picture, .swatch-burnt {
    display: none !important;
}
.price.price--on-sale .price__current .js-value {
    color: #e01a1a;
}
@media only screen and (min-width: 1041px) {
    .media-gallery.media-gallery--layout-carousel-beside .thumbnails .slider__grid {
        max-height: var(--current-slide-height, auto);
    }
}
.mnl-product .product-form .input-row {
    margin: 15px 0;
}
#infiniteoptions-container span.spb-productoptionswatch {
    border: 1px solid #e1d6d6;
}
#infiniteoptions-container .global-color-option label.spb-productdescfont {
    display: block;
    font-weight: bold;
    margin-bottom: 10px;
}
#infiniteoptions-container .spb-productoptionswatch {
    width: 40px;
    height: 40px;
    margin-right: 8px;
    border-radius: 50%;
    margin-bottom: 5px;
}
#infiniteoptions-container .global-customcolor-option label {
    margin-right: 10px;
}
#infiniteoptions-container .spb-productoptionswatchwrapper input[type="radio"]:checked + .spb-productoptionswatch {
    border: 1px solid #fff;
    box-shadow: 0px 0px 0px 2px currentColor;
}
.header-account-link.st-wishlist-details-button[data-type=manually] .st-number {
    height: 15px;
    right: -5px;
    top: 12px;
    width: 15px;
    font-size: 9px;
    font-weight: 500;
    line-height: 1em;
}
.collection-slider-row {
    margin-top: 15px;
}
.product-block__title {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
}
.global-en-option {
    margin-top: 9px;
}
.global-en-option.global-cs-option .spb-label-tooltip, .global-en-option.global-textshort-option .spb-label-tooltip {
    float: left;
    width: 150px;
}
.spb-label-tooltip {
    margin-bottom: 8px;
}
.global-en-option span input {
    width: 150px;
}
#infiniteoptions-container .text-button input[type=radio] {
    opacity: 0!important;
    position: absolute;
    top: 0;
    left: 0;
}
#infiniteoptions-container .spb-label-tooltip {
    font-weight: bold;
    margin-bottom: 6px;
}
div#infiniteoptions-container input {
    min-height: 33px;
    border: 1px solid #e8e8e1;
    padding: 0px 4px;
    border-radius: 6px;
}
#infiniteoptions-container .text-button span label {
    display: inline-block;
    position: relative;
    height: 74px;
    line-height: 24px;
    text-align: center;
    cursor: pointer;
    font-size: 14px;
    padding: 0.3rem;
    letter-spacing: .1rem;
    width: 100%;
    border: 1px solid #e8e8e1;
    text-transform: capitalize;
}
#infiniteoptions-container .text-button span label.selected {
    outline: #000 solid 1px;
    border-radius: 5px;
}
#infiniteoptions-container .text-button span label {
    height: 35px;
    width: auto;
    margin: 0 6px 6px 0;
    min-width: 35px;
    border-radius: 5px;
    color: #000;
}
#infiniteoptions-container .spb-productoptionswatchwrapper:hover .spb-swatchtooltip {
    visibility: visible;
    opacity: 1;
    padding: 5px 10px;
    z-index: 1;
    text-align: center;
    color: #fff;
    background-color: #333;
}

#infiniteoptions-container .spb-productoptionswatchwrapper .spb-swatchtooltip {
    position: absolute;
    visibility: hidden;
    opacity: 0;
    transition: opacity .3s;
    border-radius: 2px;
    bottom: 105%;
    left: 50%;
    transform: translate(-50%);
    margin-left: -3px;
    font-size: 12px;
    min-width: 95px;
}
div#infiniteoptions-container {
    margin-bottom: 10px;
    margin-top: -10px;
}
#infiniteoptions-container select {
    height: 36px;
    border: 1px solid #e8e8e1;
    padding: 0px 2px;
    border-radius: 4px;
}
.spb-label-tooltip {
    text-align: left;
    clear: both;
    margin-top: 10px;
}
span.product-sku {
    color: #170ab4;
    font-weight: 500;
}
.product-title {
    font-size: 28px;
}
.product-block-options__inner:has(.hiddenvariant), .hiddenvariant {
    display: none;
}
.product-block-options__more-label1, .product-block-options__more-label2 {
    display: inline-block;
    margin: 0 7px 12px 4px;
    line-height: 14px;
    vertical-align: middle;
}
.gm-single-product>.gm-target .gm-label.gm-sale-label {
    padding: 2px 3px !important;
    font-size: 0.9em;
}
.product-label>span {
    padding: 3px 4px;
    font-size: 0.7em;
}
.gm-product-name {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 2;
}
.mnl-product .media-gallery__inner .product-label-container {
    right: unset;
}
.page-section-spacing .page-header .breadcrumbs {
    margin-top: -0.5em;
}
ol.breadcrumbs-list {
    overflow: hidden;
    text-overflow: ellipsis;
    display: -webkit-box;
    -webkit-box-orient: vertical;
    -webkit-line-clamp: 1;
}
.cart-drawer__content .cart-item__title a.text-current {
    overflow: hidden;
    white-space: normal;
    display: -webkit-box;
    -webkit-line-clamp: 2;
    text-overflow: ellipsis;
    -webkit-box-orient: vertical;
    font-weight: 500;
    font-size: 0.8em;
}
.cart-drawer__content .cart-item__variant, .cart-drawer__content .line-item-property {
    font-size: 0.9em;
}
.img-ar--contain img {
    object-fit: cover;
}
@media (max-width: 767px) {
.product-title {
    font-size: 16px;
}
.header-account-link.st-wishlist-details-button[data-type=manually] .st-number {
    top: 14px;
}
.swatch-method-variant-images .product-block-options--swatch .product-block-options__item {
    width: 24px;
    height: 24px;
}
}