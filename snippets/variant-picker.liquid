{% comment %}
  Parameters:
  - product {Object} - Product object.
  - current_variant {Object} - Current variant object. May be false if no variant selected.
  - product_form_id {String} - Product form ID.
  - media_ratio {Number} - Media aspect ratio.
  - block {Object} - Block object.
  - update_url {Boolean} - Whether or not to update the URL when the variant changes.
  - size_chart_icon {String} - Size chart icon HTML string.

  Dependencies:
  - Custom select component

  Usage:
  {% render 'variant-picker', product: product, product_form_id: product_form_id, block: block %}
{% endcomment %}

<style>
  .option-selector__expand {
    display: none;
  }

  .option-selector__choice {
    display: inline-flex;
  }

  @media (max-width: 749px) {
    .option-selector--mobile-collapsible:not(.is-expanded) .option-selector__choice--extra {
      display: none;
    }

    .option-selector--mobile-collapsible .option-selector__expand {
      display: flex;
      align-items: center;
      justify-content: center;
      gap: 4px;
      margin: 6px auto 0;
      padding: 2px 12px;
      min-height: 24px;
      /* border: 1px solid #e25b5b; */
      background: #fff;
      color: #777;
      font-size: 14px;
      line-height: 1.2;
      cursor: pointer;
    }

    .option-selector__expand-icon {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      width: 12px;
      height: 12px;
      transition: transform 0.2s ease;
    }

    .option-selector__expand-icon svg {
      width: 12px;
      height: 12px;
    }

    .option-selector--mobile-collapsible.is-expanded .option-selector__expand-icon {
      transform: rotate(180deg);
    }
  }
</style>

{%- unless product.has_only_default_variant -%}
  {%- if product.variants_count > 1 or block.settings.show_single -%}
    <script src="{{ 'variant-picker.js' | asset_url }}" defer></script>

    <variant-picker
      class="{% if product.available %}variant-picker--product-available{% else %}variant-picker--product-unavailable{% endif %}"
      data-option-count="{{ product.options_with_values | size }}"
      data-section-id="{{ section.id }}"
      data-url="{{ product.url }}"
      data-update-url="{{ update_url | default: false }}"
      data-availability="{{ block.settings.dynamic_availability }}"
    >
      {%- for option in product.options_with_values -%}
        {%- capture option_id %}{{ product_form_id }}-{{ forloop.index }}{% endcapture -%}

        {%- liquid
          assign is_color_selector = false
          assign is_variant_image_style = false
          assign show_size_chart = false
          assign is_dropdown = false

          if settings.swatch_source == 'theme' and settings.swatch_option_name contains option.name and settings.swatch_method == 'variant-images'
            assign is_color_selector = true
            assign is_variant_image_style = true
            assign option_index0 = forloop.index0
          elsif settings.swatch_source == 'theme' and settings.swatch_option_name contains option.name and settings.swatch_method == 'swatches'
            assign is_color_selector = true
          else
            assign native_swatch_options = option.values | where: 'swatch'
            if settings.swatch_source == 'native' and native_swatch_options.size > 0
              assign is_color_selector = true
              assign is_native_swatch_style = true
            endif
          endif

          if is_variant_image_style or is_native_swatch_style
            assign img_sizes = settings.swatch_picker_image_size | append: 'px'
            assign img_widths = settings.swatch_picker_image_size | times: 2 | append: ', ' | append: settings.swatch_picker_image_size
            if settings.swatch_style == 'icon_square'
              assign img_aspect_ratio = null
              assign img_crop_align = null
            else
              assign img_aspect_ratio = 1
              assign img_crop_align = settings.swatch_crop_align
            endif
          endif

          if is_color_selector
            if settings.swatch_style == 'dropdown'
              assign is_dropdown = true
            endif
          elsif block.settings.selector_style == 'dropdown'
            assign is_dropdown = true
          endif

          if block.settings.enable_size_chart and block.settings.size_chart_variant == option.name and block.settings.size_chart_page != blank
            assign show_size_chart = true
          endif
        -%}

        {%- if show_size_chart -%}
          {%- capture size_chart_link -%}
            <modal-opener data-modal="size-chart-{{ product.id }}-{{ section.id }}">
              <button type="button" class="link block text-sm size-chart-link" aria-haspopup="dialog">
                {% if size_chart_icon %}
                  <span class="size-chart-link__icon">{{ size_chart_icon }}</span>
                {% endif %}
                <span class="size-chart-link__text underline">{{- block.settings.size_chart_label -}}</span>
              </button>
            </modal-opener>
          {%- endcapture -%}
        {%- endif -%}

        {%- if is_dropdown -%}
          {%- if is_variant_image_style -%}
            <style>
              {%- for value in option.values -%}
                {% liquid
                  assign value_image = false

                  if value.product_url != blank
                    assign product_handle = value.product_url | split: '?' | first | split: '/' | last
                    assign value_image = all_products[product_handle].featured_media
                  elsif value.variant
                    assign value_image = value.variant.featured_media
                  else
                    for variant in product.variants
                      if variant.options[option_index0] == value and variant.featured_media
                        assign value_image = variant.featured_media
                        break
                      endif
                    endfor
                  endif
                %}

                {%- if value_image -%}
                  #{{ option_id }} [data-swatch="{{ value | replace: '"', '\"' | downcase }}"] {
                    --swatch-background-color: transparent;
                    --swatch-background-image: url({{ value_image | image_url: width: 40, height: 40, crop: settings.swatch_crop_align }});
                  }
                {%- endif -%}
              {%- endfor -%}
            </style>
          {%- endif -%}

          {%- capture selector_label -%}
            <label class="label" id="{{ option_id }}-label">{{- option.name -}}</label>
          {%- endcapture -%}

          <div
            class="option-selector"
            data-selector-type="dropdown"
            data-index="{{ option.position }}"
            data-option="{{ option.name | escape }}"
            data-option-name="{{ option.name | handle }}"
          >
            {%- if show_size_chart -%}
              <div class="flex justify-between">
                {{ selector_label }}
                {{ size_chart_link }}
              </div>
            {%- else -%}
              {{ selector_label }}
            {%- endif -%}

            {%- liquid
              if current_variant
                assign selected_value = option.selected_value
              else
                assign product_url_values = option.values | where: 'product_url' | where: 'selected'
                if product_url_values != empty
                  assign selected_value = option.selected_value
                else
                  assign selected_value = ''
                endif
              endif
            -%}

            <script src="{{ 'custom-select.js' | asset_url }}" defer></script>

            {% render 'custom-select',
              id: option_id,
              option_values: option.values,
              selected_value: selected_value,
              swatches: is_color_selector,
              native_swatches: is_native_swatch_style
            %}
          </div>
        {%- else -%}
          <fieldset
            class="option-selector{% if is_color_selector and option.values.size > 20 %} option-selector--mobile-collapsible{% endif %}"
            data-selector-type="listed"
            data-index="{{ option.position }}"
            data-option="{{ option.name | escape }}"
            data-option-name="{{ option.name | handle }}"
          >
            {%- if show_size_chart -%}
              <div class="flex justify-between">
                <legend class="label">{{- option.name -}}</legend>
                {{ size_chart_link }}
              </div>
            {%- else -%}
              <legend class="label">
                {{- option.name -}}
                {% if is_color_selector -%}
                  : <span class="option-selector__label-value js-color-text">
                    {%- if current_variant -%}
                      {{- option.selected_value -}}
                    {%- endif -%}
                  </span>
                {% endif %}
              </legend>
            {%- endif -%}

            <div class="option-selector__btns flex flex-wrap">
              {%- for value in option.values -%}
                {%- assign value_index0 = forloop.index0 -%}

                {%- if is_variant_image_style -%}
                  {% liquid
                    if value.product_url != blank
                      assign product_handle = value.product_url | split: '?' | first | split: '/' | last
                      assign value_image = all_products[product_handle].featured_media
                    elsif value.variant
                      assign value_image = value.variant.featured_media
                    else
                      for variant in product.variants
                        if variant.options[option_index0] == value and variant.featured_media
                          assign value_image = variant.featured_media
                          break
                        endif
                      endfor
                    endif
                  %}

                  {%- capture label_attrs -%}
                    class="opt-label opt-label--image"
                    style="background-color: var(--{{ value.name | handle }});"
                  {%- endcapture -%}

                  {%- capture label_content -%}
                    <div class="opt-label__media media">
                      {%- render 'image',
                        image: value_image,
                        sizes: img_sizes,
                        widths: img_widths,
                        custom_aspect_ratio: img_aspect_ratio,
                        custom_crop: img_crop_align
                      -%}
                    </div>
                    <span class="{% if settings.swatch_style != 'listed' %}visually-hidden {% endif %}js-value">
                      {{ value.name | escape }}
                    </span>
                  {%- endcapture -%}

                {%- elsif settings.swatch_source == 'native' and value.swatch.image -%}
                  {%- capture label_attrs -%}
                    class="opt-label opt-label--image"
                  {%- endcapture -%}

                  {%- capture label_content -%}
                    <div class="opt-label__media media">
                      {%- render 'image',
                        image: value.swatch.image,
                        sizes: img_sizes,
                        widths: img_widths,
                        custom_aspect_ratio: img_aspect_ratio,
                        custom_crop: img_crop_align
                      -%}
                    </div>
                    <span class="{% if settings.swatch_style != 'listed' %}visually-hidden {% endif %}js-value">
                      {{ value.name | escape }}
                    </span>
                  {%- endcapture -%}

                {%- elsif settings.swatch_source == 'native' and value.swatch.color -%}
                  {%- capture label_attrs -%}
                    class="opt-label opt-label--swatch btn relative"
                    data-swatch="{{ value | replace: '"', '' | downcase }}"
                    style="--swatch-background-color: rgb({{ value.swatch.color.rgb }})"
                  {%- endcapture -%}

                  {%- capture label_content -%}
                    <span class="{% if settings.swatch_style != 'listed' %}visually-hidden {% endif %}js-value">
                      {{ value.name | escape }}
                    </span>
                  {%- endcapture -%}

                {%- else -%}
                  {%- liquid
                    assign is_swatch = false
                    if is_color_selector and settings.swatch_method == 'swatches'
                      assign is_swatch = true
                    endif
                  -%}

                  {%- capture label_attrs -%}
                    class="opt-label {% if is_swatch %}opt-label--swatch{% else %}opt-label--btn{% endif %} btn relative text-center"
                    {% if is_swatch %}data-swatch="{{ value | replace: '"', '' | downcase }}"{% endif %}
                    title="{{ value }}"
                    data-variant-value="{{ value | replace: ' ','_' | handle }}"
                    style="background-color: var(--{{ value | handle }});{% if value.variant.featured_image %} background-image: url({{ value.variant.featured_image | image_url: width: 50, height: 50, crop: 'center' }}); background-position: center; background-size: contain;{% endif %}"
                  {%- endcapture -%}

                  {%- capture label_content -%}
                    <span class="{% if is_swatch and settings.swatch_style != 'listed' %}visually-hidden {% endif %}js-value">
                      {{ value.name | escape }}
                    </span>
                  {%- endcapture -%}
                {%- endif -%}

                <span class="option-selector__choice{% if is_color_selector and option.values.size > 20 and forloop.index > 20 %} option-selector__choice--extra{% endif %}">
                  <input
                    type="radio"
                    class="opt-btn visually-hidden focus-label js-option{% if value.available == false %} is-unavailable{% endif %}"
                    name="{{ option_id }}-option"
                    id="{{ option_id }}-opt-{{ value_index0 }}"
                    value="{{ value | escape }}"
                    data-value-id="{{ value.id }}"
                    {%- if value.variant != blank %} data-variant-id="{{ value.variant.id }}"{% endif %}
                    {%- if value.product_url != blank %} data-product-url="{{ value.product_url }}"{% endif %}
                    required
                    {%- if current_variant %}
                      {%- if value.selected %} checked{% endif %}
                    {%- endif %}
                  >

                  <label for="{{ option_id }}-opt-{{ value_index0 }}" {{ label_attrs }}>
                    {{- label_content -}}
                  </label>
                </span>
              {%- endfor -%}
            </div>

            {%- if is_color_selector and option.values.size > 20 -%}
              <button
                type="button"
                class="option-selector__expand js-swatch-expand"
                aria-expanded="false"
                data-total-text="Total {{ option.values.size }} colors"
              >
                Total {{ option.values.size }} colors
                <span class="option-selector__expand-icon">
                  {% render 'icon-chevron-down' %}
                </span>
              </button>
            {%- endif -%}
          </fieldset>
        {%- endif -%}
      {%- endfor -%}

      {%- if current_variant %}
        <script type="application/json">
          {{- current_variant | json -}}
        </script>
      {%- endif -%}
    </variant-picker>

    {%- capture swatch_expand_icon -%}
      {% render 'icon-chevron-down' %}
    {%- endcapture -%}

    <script>
      const swatchExpandIcon = {{ swatch_expand_icon | json }};

      document.addEventListener('click', function(event) {
        const button = event.target.closest('.js-swatch-expand');
        if (!button) return;

        const selector = button.closest('.option-selector--mobile-collapsible');
        if (!selector) return;

        const expanded = selector.classList.toggle('is-expanded');
        button.setAttribute('aria-expanded', expanded ? 'true' : 'false');

        const totalText = button.dataset.totalText || button.textContent.trim();

        button.innerHTML = expanded
          ? 'Show less <span class="option-selector__expand-icon">' + swatchExpandIcon + '</span>'
          : totalText + ' <span class="option-selector__expand-icon">' + swatchExpandIcon + '</span>';
      });
    </script>
  {%- endif -%}
{%- endunless -%}