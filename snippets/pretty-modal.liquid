<style>
.pretty-modal-overlay {
  display: none;
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(8px);
  -webkit-backdrop-filter: blur(8px);
  align-items: center;
  justify-content: center;
  z-index: 9999;
  opacity: 0;
  transition: opacity 300ms ease;
}
.pretty-modal-overlay.active { display: flex; opacity: 1; }

.pretty-modal-content {
  position: relative;
  min-width: 45vw;
  min-height: 45vh;
  max-width: 95vw;
  max-height: 95vh;
  background: #fff;
  border-radius: 12px;
  overflow: hidden;
  box-shadow: 0 20px 40px rgba(0,0,0,0.3);
  transform: scale(0.9);
  opacity: 0;
  transition: transform 300ms ease, opacity 300ms ease;
  padding: 10px;
}
.pretty-modal-overlay.active .pretty-modal-content {
  transform: scale(1);
  opacity: 1;
}

.pretty-modal-body {
  max-height: 95vh;
  overflow-y: auto;
  -webkit-overflow-scrolling: touch;
  display: flex;
  justify-content: center;
}
.pretty-modal-body img {
  max-height: 95vh;
  max-width: 95vw;
  border: initial !important;
}
.pretty-modal-close {
  position: absolute;
  top: 12px;
  right: 12px;
  width: 44px;
  height: 44px;
  background: rgba(0,0,0,0.15);
  border: none;
  border-radius: 50%;
  cursor: pointer;
  z-index: 1;
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 0;
}
.pretty-modal-close:hover { background: rgba(0,0,0,0.3); }
.pretty-modal-close svg { width: 24px; height: 24px; fill: #fff; opacity: 0.75;}

@media screen and (max-width: 767px) {
.pretty-modal-content {
  width: calc(100% - 32px);
  max-width: 95vw;
  min-height: 55vh;
  max-height: 95vh;
}
}
</style>

<script>
document.addEventListener('DOMContentLoaded', () => {
  const triggers = document.querySelectorAll('.pretty-modal');
  let overlay = null;
  let currentScrollY = 0;

  const closeSvg = `<svg viewBox="0 0 1024 1024" xmlns="http://www.w3.org/2000/svg" width="24" height="24"><path d="M927.846568 511.997953c0-229.315756-186.567139-415.839917-415.838893-415.839917-229.329059 0-415.85322 186.524161-415.85322 415.839917 0 229.300406 186.524161 415.84094 415.85322 415.84094C741.278405 927.838893 927.846568 741.29836 927.846568 511.997953M512.007675 868.171955c-196.375529 0-356.172979-159.827125-356.172979-356.174002 0-196.374506 159.797449-356.157629 356.172979-356.157629 196.34483 0 356.144326 159.783123 356.144326 356.157629C868.152001 708.34483 708.352505 868.171955 512.007675 868.171955" fill="#000000"/><path d="M682.378947 642.227993 553.797453 513.264806 682.261267 386.229528c11.661597-11.514241 11.749602-30.332842 0.234337-41.995463-11.514241-11.676947-30.362518-11.765975-42.026162-0.222057L511.888971 471.195665 385.223107 344.130711c-11.602246-11.603269-30.393217-11.661597-42.025139-0.059352-11.603269 11.618619-11.603269 30.407544-0.059352 42.011836l126.518508 126.887922L342.137823 639.104863c-11.662621 11.543917-11.780301 30.305213-0.23536 41.96988 5.830799 5.89015 13.429871 8.833179 21.086248 8.833179 7.53972 0 15.136745-2.8847 20.910239-8.569166l127.695311-126.311801L640.293433 684.195827c5.802146 5.8001 13.428847 8.717546 21.056572 8.717546 7.599072 0 15.165398-2.917446 20.968567-8.659217C693.922864 672.681586 693.950494 653.889591 682.378947 642.227993" fill="#000000"/></svg>`;

  const createOverlay = () => {
    if (overlay) return;

    overlay = document.createElement('div');
    overlay.className = 'pretty-modal-overlay';
    overlay.innerHTML = `
      <div class="pretty-modal-content">
        <span class="pretty-modal-close" aria-label="Close">${closeSvg}</span>
        <div class="pretty-modal-body"></div>
      </div>
    `;
    document.body.appendChild(overlay);

    const closeBtn = overlay.querySelector('.pretty-modal-close');
    const bodyEl = overlay.querySelector('.pretty-modal-body'); // 提前定义

    const close = () => {
      overlay.classList.remove('active');
      document.body.style.overflow = '';
      window.scrollTo(0, currentScrollY);
      setTimeout(() => { overlay?.remove(); overlay = null; }, 300);
    };

    overlay.addEventListener('click', e => { if (e.target === overlay) close(); });
    closeBtn.addEventListener('click', close);
    document.addEventListener('keydown', e => {
      if (e.key === 'Escape' && overlay?.classList.contains('active')) close();
    });

    overlay.dataset.bodyEl = bodyEl;
  };

  triggers.forEach(t => {
    t.style.cursor = 'pointer';
    t.addEventListener('click', e => {
      e.preventDefault();
      const id = t.dataset.modalId;
      const target = document.getElementById(id);
      if (!target) return;

      createOverlay();
      const bodyEl = overlay.querySelector('.pretty-modal-body');

      currentScrollY = window.scrollY;
      document.body.style.overflow = 'hidden';

      const clone = target.cloneNode(true);
      clone.removeAttribute('id');
      clone.style.display = clone.style.visibility = '';
      bodyEl.innerHTML = '';
      bodyEl.appendChild(clone);

      requestAnimationFrame(() => overlay.classList.add('active'));
    });
  });
});
</script>