<div class="deal-banner">
  <div class="deal-list-slider">
    <div class="deal-slider-wrapper">
  {% assign deals = discount_sell_title | split: '##' %}
      {% assign valid_deals = '' %}

      {% for deal in deals %}
        {% assign deal_trimmed = deal | strip %}
        {% if deal_trimmed != '' %}
          {% assign valid_deals = valid_deals | append: deal | append: '##' %}
        {% endif %}
      {% endfor %}

      {% assign valid_deals = valid_deals | split: '##' %}
      
      {% for deal in valid_deals %}
        {% assign deal_details = deal | split: ',' %}
        <div class="deal-slide{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index }}">
          <div class="deal-list">
            <div class="deal-left">
                {% assign deal_percentage = deal_details[0] | split: ':' | last | strip | remove: '"' %}
                {% assign deal_off = deal_details[1] | split: ':' | last | strip | remove: '"' %}
                <span class="dealdiscount">{{ deal_percentage }}</span>
                <span class="dealoff">{{ deal_off }}</span>
            </div>
            <div class="deal-right">
                <div class="deal-header">
                    {% assign deal_brief = deal_details[2] | split: ':' | last | strip | remove: '"' %}
                    {% assign deal_title = deal_details[3] | split: ':' | last | strip | remove: '"' %}
                    {% assign deal_code = deal_details[4] | split: ':' | last | strip | remove: '"' %}
                    <p class="deal-brief">{{ deal_brief }}</p>
                    <p class="deal-title">{{ deal_title }}</p>
                    <p class="deal-coupon"><span class="deal-coupon-left">Code</span>: <span class="deal-code">{{ deal_code }}</span></p>
                </div>
                <div class="deal-additional-info">
                    {% assign deal_additional_info = deal_details[5] | split: ':' | last | strip | remove: '"' %}
                    <p>{{ deal_additional_info }}</p>
                </div>
            </div>
          </div>
        </div>
      {% endfor %}
    </div>

    {% if valid_deals.size > 1 %}
    <div class="deal-navigation">
      {% for deal in valid_deals %}
        <button class="deal-dot{% if forloop.first %} active{% endif %}" data-index="{{ forloop.index }}" aria-label="Go to slide {{ forloop.index }}"></button>
      {% endfor %}
    </div>
    {% endif %}
  </div>
</div>
      <style>
      .deal-banner {
          margin-bottom: 8px;
      }
      
      .deal-list-slider {
          position: relative;
          overflow: hidden;
      }
      
      .deal-slider-wrapper {
          position: relative;
          width: 100%;
          display: grid;
      }
      
      .deal-slide {
          grid-column: 1;
          grid-row: 1;
          opacity: 0;
          visibility: hidden;
          transition: opacity 0.4s ease-in-out, visibility 0.4s ease-in-out;
          pointer-events: none;
      }
      
      .deal-slide.active {
          opacity: 1;
          visibility: visible;
          pointer-events: auto;
      }
      
      .deal-list {
          align-items: center;
          display: flex;
          padding: 1rem;
          background: #fff;
          border-radius: 7px;
      }
      
      .deal-left {
          align-items: center;
          align-self: stretch;
          border-radius: 8px;
          display: flex;
          border: 2px dashed #e2e4e8;
          flex: 0 0 20%;
          flex-direction: column;
          justify-content: center;
          position: relative;
          text-align: center;
          margin-right: 10px;
          line-height: 1;
      }
      
      .deal-list p {
          margin: 0;
          line-height: 1.5;
      }
      
      .deal-title {
          color: #333;
          display: -webkit-box;
          font-weight: 600;
          overflow: hidden;
          text-overflow: ellipsis;
          word-break: break-word;
          -webkit-line-clamp: 2;
          font-size: 1.2em;
          -webkit-box-orient: vertical;
      }
      
      .dealdiscount {
          font-weight: 700;
          font-size: 1.5em;
          color: #3258b3;
      }
      
      .deal-additional-info {
          font-size: 12px;
          font-size: 0.7em;
          color: #aea9a9;
      }
      
      .deal-coupon-left {
          text-transform: uppercase;
      }
      
      .deal-code {
          font-weight: 700;
          background: #edf2ff;
          border-radius: 4px;
          padding: 1px 6px;
          border: 2px dashed #e2e4e8;
          font-size: 1.2em;
          cursor: pointer;
          transition: background-color 0.2s ease;
      }
      
      .deal-code:hover {
          background: #d6e2ff;
      }
      
      .deal-coupon {
          margin-bottom: 6px;
      }
      
      .deal-brief {
          font-size: 13px;
      }

      .deal-navigation {
          text-align: center;
          margin-top: 8px;
          display: flex;
          justify-content: center;
          gap: 8px;
      }
      
      .deal-navigation .deal-dot {
          width: 10px;
          height: 10px;
          border-radius: 50%;
          background-color: #ccc;
          border: none;
          cursor: pointer;
          padding: 0;
          transition: all 0.3s ease;
          outline: none;
      }
      
      .deal-navigation .deal-dot:hover {
          background-color: #999;
          transform: scale(1.2);
      }
      
      .deal-navigation .deal-dot.active {
          background-color: #3258b3;
          width: 24px;
          border-radius: 5px;
      }
      
      .copy-tooltip {
          position: absolute;
          background: #333;
          color: #fff;
          padding: 6px 10px;
          border-radius: 4px;
          white-space: nowrap;
          z-index: 1000;
          pointer-events: none;
          font-size: 11px;
      }
      </style>
      <script>
      // Cart Deals Carousel Class
      class CartDealsCarousel {
        constructor(container) {
          this.container = container;
          this.slides = container.querySelectorAll('.deal-slide');
          this.dots = container.querySelectorAll('.deal-dot');
          this.currentIndex = 0;
          this.autoPlayInterval = 5000;
          this.hoverInterval = 10000;
          this.timer = null;
          this.isPaused = false;
          
          if (this.slides.length === 0) return;
          
          this.init();
        }
        
        init() {
          // Show first slide
          this.showSlide(0);
          
          // Setup event listeners
          this.setupDots();
          this.setupHover();
          
          // Start auto play
          this.startAutoPlay();
        }
        
        showSlide(index) {
          // Validate index
          if (index < 0) index = this.slides.length - 1;
          if (index >= this.slides.length) index = 0;
          
          const currentSlide = this.slides[this.currentIndex];
          const nextSlide = this.slides[index];
          
          // If same slide and already active, do nothing
          if (index === this.currentIndex && nextSlide && nextSlide.classList.contains('active')) {
            return;
          }
          
          // Remove active class from all slides first
          this.slides.forEach(slide => {
            slide.classList.remove('active');
          });
          
          // Add active class to next slide
          if (nextSlide) {
            nextSlide.classList.add('active');
          }
          
          this.currentIndex = index;
          
          // Update dots
          this.updateDots();
        }
        
        nextSlide() {
          const nextIndex = (this.currentIndex + 1) % this.slides.length;
          this.showSlide(nextIndex);
        }
        
        goToSlide(index) {
          this.showSlide(index);
          this.resetAutoPlay();
        }
        
        updateDots() {
          this.dots.forEach((dot, index) => {
            if (index === this.currentIndex) {
              dot.classList.add('active');
            } else {
              dot.classList.remove('active');
            }
          });
        }
        
        setupDots() {
          this.dots.forEach((dot, index) => {
            dot.addEventListener('click', () => {
              this.goToSlide(index);
            });
          });
        }
        
        setupHover() {
          this.slides.forEach(slide => {
            slide.addEventListener('mouseenter', () => {
              this.pauseAutoPlay();
              // Use longer interval when hovering
              this.autoPlayInterval = this.hoverInterval;
            });
            
            slide.addEventListener('mouseleave', () => {
              // Reset to normal interval
              this.autoPlayInterval = 5000;
              this.resumeAutoPlay();
            });
          });
        }
        
        startAutoPlay() {
          if (this.timer) this.stopAutoPlay();
          this.timer = setInterval(() => {
            if (!this.isPaused) {
              this.nextSlide();
            }
          }, this.autoPlayInterval);
        }
        
        stopAutoPlay() {
          if (this.timer) {
            clearInterval(this.timer);
            this.timer = null;
          }
        }
        
        pauseAutoPlay() {
          this.isPaused = true;
        }
        
        resumeAutoPlay() {
          this.isPaused = false;
        }
        
        resetAutoPlay() {
          this.stopAutoPlay();
          this.startAutoPlay();
        }
        
        destroy() {
          this.stopAutoPlay();
          this.dots.forEach(dot => {
            const newDot = dot.cloneNode(true);
            dot.parentNode.replaceChild(newDot, dot);
          });
        }
      }
      
      // Initialize cart deals carousel
      function initCartDeals() {
        const cartDrawer = document.querySelector('cart-drawer');
        if (!cartDrawer) return;
        
        const dealBanner = cartDrawer.querySelector('.deal-banner');
        if (!dealBanner) return;
        
        const slides = dealBanner.querySelectorAll('.deal-slide');
        if (slides.length === 0) return;
        
        // Check if already initialized
        if (dealBanner.dataset.initialized === 'true') return;
        dealBanner.dataset.initialized = 'true';
        
        // Destroy existing carousel if any
        if (dealBanner.carousel) {
          dealBanner.carousel.destroy();
          dealBanner.carousel = null;
        }
        
        // Create new carousel instance
        dealBanner.carousel = new CartDealsCarousel(dealBanner);
        
        // Force show first slide if not already active
        const firstSlide = slides[0];
        if (firstSlide && !firstSlide.classList.contains('active')) {
          dealBanner.carousel.showSlide(0);
        }
      }
      
      // Initialize copy functionality
      function initCopyCode() {
        const cartDrawer = document.querySelector('cart-drawer');
        if (!cartDrawer) return;
        
        const codeElements = cartDrawer.querySelectorAll('.deal-code');
        codeElements.forEach(function(element) {
          if (element.dataset.copyInitialized === 'true') return;
          element.dataset.copyInitialized = 'true';
          
          element.style.position = 'relative';
          element.addEventListener('click', function() {
            const codeText = element.textContent.trim();
            
            // Try modern clipboard API first
            if (navigator.clipboard && navigator.clipboard.writeText) {
              navigator.clipboard.writeText(codeText)
                .then(function() {
                  showCopyTooltip(element);
                })
                .catch(function(err) {
                  console.error('Copy failed: ', err);
                  fallbackCopy(codeText, element);
                });
            } else {
              // Fallback for older browsers
              fallbackCopy(codeText, element);
            }
          });
        });
      }
      
      function showCopyTooltip(element) {
        // Remove existing tooltip if any
        const existingTooltip = element.querySelector('.copy-tooltip');
        if (existingTooltip) {
          existingTooltip.remove();
        }
        
        const tooltip = document.createElement('div');
        tooltip.className = 'copy-tooltip';
        tooltip.textContent = 'Copied, use it at checkout.';
        element.appendChild(tooltip);
        
        setTimeout(function() {
          if (tooltip.parentNode) {
            tooltip.remove();
          }
        }, 1500);
      }
      
      function fallbackCopy(text, element) {
        const textArea = document.createElement('textarea');
        textArea.value = text;
        textArea.style.position = 'fixed';
        textArea.style.opacity = '0';
        document.body.appendChild(textArea);
        textArea.select();
        
        try {
          document.execCommand('copy');
          showCopyTooltip(element);
        } catch (err) {
          console.error('Fallback copy failed: ', err);
        }
        
        document.body.removeChild(textArea);
      }
      
      // Initialize with retry mechanism
      function initCartDealsWithRetry(retries = 3, delay = 100) {
        let attempt = 0;
        const tryInit = function() {
          attempt++;
          const cartDrawer = document.querySelector('cart-drawer');
          if (!cartDrawer) {
            if (attempt < retries) {
              setTimeout(tryInit, delay);
            }
            return;
          }
          
          const dealBanner = cartDrawer.querySelector('.deal-banner');
          const slides = dealBanner ? dealBanner.querySelectorAll('.deal-slide') : [];
          
          if (slides.length === 0) {
            if (attempt < retries) {
              setTimeout(tryInit, delay);
            }
            return;
          }
          
          // Found slides, initialize
          initCartDeals();
          initCopyCode();
        };
        
        tryInit();
      }
      
      // Initialize when drawer opens
      document.addEventListener('cart-drawer-open', function() {
        initCartDealsWithRetry(5, 150);
      });
      
      // Initialize when drawer is refreshed
      document.addEventListener('cart-drawer:refresh', function() {
        const cartDrawer = document.querySelector('cart-drawer');
        if (cartDrawer) {
          const dealBanner = cartDrawer.querySelector('.deal-banner');
          if (dealBanner) {
            dealBanner.dataset.initialized = 'false';
            if (dealBanner.carousel) {
              dealBanner.carousel.destroy();
              dealBanner.carousel = null;
            }
            const codeElements = cartDrawer.querySelectorAll('.deal-code');
            codeElements.forEach(function(el) {
              el.dataset.copyInitialized = 'false';
            });
          }
        }
        
        initCartDealsWithRetry(5, 200);
      });
      
      // Initialize on page load
      if (document.readyState === 'loading') {
        document.addEventListener('DOMContentLoaded', function() {
          initCartDeals();
          initCopyCode();
        });
      } else {
        initCartDeals();
        initCopyCode();
      }
      </script>