      {%- assign cm_data = "1Y|1Y:51:48.5:48.5:68:1-2,2Y|2Y:53.5:51:51:75:2-3,3Y|3Y:56:53.5:53.5:82:2-3,4Y|4Y:58.5:56:56:88:4-5,5Y|5Y:61:58.5:58.5:93:4-5,6Y|6Y:63.5:61:63.5:98:6-7,7Y|7Y:66:63.5:68.5:102:6-7,8Y|8Y:68.5:66:71:107:8-9,9Y|9Y:71:68.5:74:111:8-9,10Y|10Y:74:71:79:115:10-11,11Y|11Y:77.5:74:84:120:10-11,12Y|12Y:81:76:86.5:125:12-13,13Y|13Y:84:79:87.5:129:12-13,14Y|14Y:86.5:81:89:132:14-15" | split: ',' -%}
