<script>
document.addEventListener('DOMContentLoaded', () => {
  const radios = document.querySelectorAll('input[name="properties[Size]"]');
  const chart = document.getElementById('size-chart-table');
  const customForm = document.getElementById('custom-size-form');
  const productForm = document.querySelector('#{{product_form_id}}');

  // Initialize payment buttons state based on form validation
  function updatePaymentButtonsState() {
    const selectedSize = document.querySelector('input[name="properties[Size]"]:checked');
    if (!selectedSize) {
      disablePaymentButtons();
      return;
    }
    
    if (selectedSize.value === 'Custom Size') {
      // Check if custom form is valid
      const unitRadio = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
      const customInputs = document.querySelectorAll('#custom-size-form input[type="number"][required]');
      let isValid = true;
      
      if (!unitRadio) {
        isValid = false;
      } else {
        customInputs.forEach(input => {
          if (!input.disabled && (!input.value || input.value.trim() === '' || parseFloat(input.value) <= 0)) {
            isValid = false;
          }
        });
      }
      
      if (!isValid) {
        disablePaymentButtons();
      } else {
        enablePaymentButtons();
      }
    } else {
      enablePaymentButtons();
    }
  }

  // begin url param selected size
  // Function to normalize size value for comparison (ignore case, handle spaces, _, -)
  function normalizeSize(size) {
    if (!size) return '';
    // Convert to lowercase and replace spaces, underscores, and hyphens with a single space
    let normalized = size.toLowerCase().trim().replace(/[\s_-]+/g, ' ');
    // Remove leading "us" prefix before numeric size (e.g. "us2", "us 2" -> "2")
    normalized = normalized.replace(/^us\s*(\d)/, '$1');
    return normalized;
  }
  
  // Function to check if two sizes match (ignoring case, spaces, _, -)
  function sizesMatch(size1, size2) {
    const normalized1 = normalizeSize(size1);
    const normalized2 = normalizeSize(size2);
    return normalized1 === normalized2;
  }
  
  // Check URL parameter for size and auto-select if found
  function selectSizeFromURL() {
    try {
      // Try to get size from URL - check both search and full href
      let urlSize = null;
      
      // Method 1: Use URLSearchParams (standard way)
      if (window.location.search) {
        const urlParams = new URLSearchParams(window.location.search);
        urlSize = urlParams.get('size');
      }
      
      // Method 2: Parse from full URL if search params didn't work
      if (!urlSize) {
        const fullUrl = window.location.href;
        const match = fullUrl.match(/[?&]size=([^&]*)/i);
        if (match && match[1]) {
          urlSize = decodeURIComponent(match[1].replace(/\+/g, ' '));
        }
      }
      
      // Method 3: Also check hash if present
      if (!urlSize && window.location.hash) {
        const hashMatch = window.location.hash.match(/[?&]size=([^&]*)/i);
        if (hashMatch && hashMatch[1]) {
          urlSize = decodeURIComponent(hashMatch[1].replace(/\+/g, ' '));
        }
      }
      
      if (!urlSize) {
        return false;
      }
      
      // Trim and clean the size value
      urlSize = urlSize.trim();
      
      // Find matching size in available options
      for (const radio of radios) {
        if (sizesMatch(radio.value, urlSize)) {
          // Select the radio button
          radio.checked = true;
          // Trigger change event to update UI
          radio.dispatchEvent(new Event('change', { bubbles: true }));
          return true;
        }
      }
    } catch (e) {
      console.error('Error selecting size from URL:', e);
    }
    
    return false;
  }
  
  // Function to attempt size selection from URL
  function trySelectSizeFromURL() {
    if (radios.length > 0) {
      const alreadySelected = document.querySelector('input[name="properties[Size]"]:checked');
      if (!alreadySelected) {
        return selectSizeFromURL();
      }
    }
    return false;
  }
  
  // Try to select size from URL parameter first (only if no size is already selected)
  // Use setTimeout to ensure DOM is fully ready
  setTimeout(function() {
    trySelectSizeFromURL();
  }, 100);
  
  // Also try after window load (in case of async content loading)
  window.addEventListener('load', function() {
    setTimeout(function() {
      trySelectSizeFromURL();
    }, 50);
  });
  // end url param selected size  

  // Initialize size display if a size is already selected
  const defaultSize = document.querySelector('input[name="properties[Size]"]:checked');
  if (defaultSize) {
    const sizeDisplay = document.getElementById('size-select-size');
    if (sizeDisplay) {
      sizeDisplay.textContent = defaultSize.value;
    }
    // Initialize disabled state for custom-size-form inputs
    const isCustom = defaultSize.value === 'Custom Size';
    const customFormInputs = document.querySelectorAll('#custom-size-form input[type="number"]');
    const unitRadios = document.querySelectorAll('input[name="properties[Measurement Unit]"]');
    
    customFormInputs.forEach(input => {
      if (isCustom) {
        input.removeAttribute('disabled');
      } else {
        input.setAttribute('disabled', 'disabled');
      }
    });
    
    // Initialize disabled state for unit toggle radios
    const unitToggleSwitch = document.querySelector('#custom-size-form .unit-toggle-switch');
    unitRadios.forEach(radio => {
      if (isCustom) {
        radio.removeAttribute('disabled');
      } else {
        radio.setAttribute('disabled', 'disabled');
      }
    });
    
    // Initialize disabled class for toggle switch
    if (unitToggleSwitch) {
      if (isCustom) {
        unitToggleSwitch.classList.remove('disabled');
      } else {
        unitToggleSwitch.classList.add('disabled');
      }
    }
    
    // Update payment buttons state on initialization
    updatePaymentButtonsState();
  } else {
    // No size selected, disable payment buttons
    disablePaymentButtons();
  }

  radios.forEach(radio => {
    radio.addEventListener('change', function() {
      // 清除所有 selected
      document.querySelectorAll('.style-select-item, .custom-size-select-item').forEach(el => {
        el.classList.remove('selected');
      });
      // 给当前 label 添加 selected
      this.closest('label').classList.add('selected');

      // Update size display text
      const sizeDisplay = document.getElementById('size-select-size');
      if (sizeDisplay) {
        sizeDisplay.textContent = this.value;
      }

      const isCustom = this.value === 'Custom Size';
      if (chart) {
        chart.style.display = isCustom ? 'none' : 'block';
      }
      customForm.style.display = isCustom ? 'block' : 'none';

      // Enable/disable inputs in custom-size-form based on selection
      const customFormInputs = document.querySelectorAll('#custom-size-form input[type="number"]');
      const unitRadios = document.querySelectorAll('input[name="properties[Measurement Unit]"]');
      
      customFormInputs.forEach(input => {
        if (isCustom) {
          input.removeAttribute('disabled');
        } else {
          input.setAttribute('disabled', 'disabled');
        }
      });
      
      // Enable/disable unit toggle radios
      const unitToggleSwitch = document.querySelector('#custom-size-form .unit-toggle-switch');
      unitRadios.forEach(radio => {
        if (isCustom) {
          radio.removeAttribute('disabled');
        } else {
          radio.setAttribute('disabled', 'disabled');
        }
      });
      
      // Add/remove disabled class to toggle switch for visual feedback
      if (unitToggleSwitch) {
        if (isCustom) {
          unitToggleSwitch.classList.remove('disabled');
        } else {
          unitToggleSwitch.classList.add('disabled');
        }
      }
      
      // Update payment buttons state when size changes
      updatePaymentButtonsState();

      if (!isCustom && chart) {
        // Dynamically get all sizes from DOM (excluding "Custom Size")
        const allSizes = Array.from(document.querySelectorAll('input[name="properties[Size]"]'))
          .map(radio => radio.value)
          .filter(size => size !== 'Custom Size');
        const idx = allSizes.indexOf(this.value);
        const show = idx <= 1 ? allSizes.slice(0, 3) :
                    idx >= allSizes.length - 2 ? allSizes.slice(-3) :
                    allSizes.slice(idx-1, idx+2);

        document.querySelectorAll('#size-chart-table tr[data-size]').forEach(row => {
          const size = row.dataset.size;
          row.style.display = show.includes(size) ? 'table-row' : 'none';
          row.classList.toggle('highlight', size === this.value);
        });
      }
    });
  });

  // Chart Unit toggle switch handler
  const chartUnitRadios = document.querySelectorAll('input[name="chart-unit"]');
  if (chartUnitRadios.length > 0) {
    // Initialize table display based on default checked radio
    const defaultChartUnit = document.querySelector('input[name="chart-unit"]:checked');
    if (defaultChartUnit) {
      const unit = defaultChartUnit.value.toUpperCase();
      const inchTable = document.querySelector('.inch-table');
      const cmTable = document.querySelector('.cm-table');
      if (inchTable) inchTable.style.display = unit === 'INCH' ? 'table' : 'none';
      if (cmTable) cmTable.style.display = unit === 'CM' ? 'table' : 'none';
    }
    
    chartUnitRadios.forEach(radio => {
      radio.addEventListener('change', function() {
        const unit = this.value.toUpperCase();
        const inchTable = document.querySelector('.inch-table');
        const cmTable = document.querySelector('.cm-table');
        if (inchTable) inchTable.style.display = unit === 'INCH' ? 'table' : 'none';
        if (cmTable) cmTable.style.display = unit === 'CM' ? 'table' : 'none';
      });
    });
  }
  
  // Allow clicking on chart toggle switch background to toggle
  const chartToggleSwitch = document.querySelector('.chart-unit-toggle');
  if (chartToggleSwitch) {
    chartToggleSwitch.addEventListener('click', function(e) {
      // Only handle clicks on the switch background or slider, not on labels
      // Labels will trigger their associated radio buttons automatically via 'for' attribute
      if (e.target === chartToggleSwitch || e.target.classList.contains('unit-toggle-slider')) {
        e.preventDefault();
        e.stopPropagation();
        const currentChecked = document.querySelector('input[name="chart-unit"]:checked');
        if (currentChecked && currentChecked.id === 'chart-unit-in') {
          document.getElementById('chart-unit-cm').checked = true;
          document.getElementById('chart-unit-cm').dispatchEvent(new Event('change', { bubbles: true }));
        } else {
          document.getElementById('chart-unit-in').checked = true;
          document.getElementById('chart-unit-in').dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
  }

  // Measurement Unit toggle switch handler (for custom-size-form)
  const unitRadios = document.querySelectorAll('input[name="properties[Measurement Unit]"]');
  
  // Conversion constants
  const INCH_TO_CM = 2.54;
  const CM_TO_INCH = 1 / 2.54;
  
  // Function to convert value between units
  function convertValue(value, fromUnit, toUnit) {
    if (fromUnit === toUnit || isNaN(value)) return value;
    if (fromUnit === 'in' && toUnit === 'cm') {
      return parseFloat((value * INCH_TO_CM).toFixed(2));
    } else if (fromUnit === 'cm' && toUnit === 'in') {
      return parseFloat((value * CM_TO_INCH).toFixed(2));
    }
    return value;
  }
  
  // Store original min/max values and current unit for each input
  const inputDataMap = new Map();
  const numberInputs = document.querySelectorAll('#custom-size-form input[type="number"]');
  numberInputs.forEach(input => {
    const minUnit = input.getAttribute('data-min-unit') || 'in';
    const maxUnit = input.getAttribute('data-max-unit') || 'in';
    const originalMin = parseFloat(input.getAttribute('min'));
    const originalMax = parseFloat(input.getAttribute('max'));
    
    inputDataMap.set(input, {
      originalMin: originalMin,
      originalMax: originalMax,
      minUnit: minUnit,
      maxUnit: maxUnit,
      currentUnit: 'in' // Will be updated
    });
  });
  
  // Function to update input unit display and convert values
  function updateInputUnits() {
    const checkedUnit = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
    const unitValue = checkedUnit ? checkedUnit.value : 'in';
    const unitDisplay = unitValue === 'in' ? 'in' : 'cm';
    
    // Update unit display
    document.querySelectorAll('.input-unit').forEach(unitSpan => {
      unitSpan.textContent = unitDisplay;
    });
    
    // Convert input values and min/max
    numberInputs.forEach(input => {
      if (!input.disabled) {
        const data = inputDataMap.get(input);
        if (!data) return;
        
        const previousUnit = data.currentUnit;
        
        // Only convert if unit actually changed
        if (previousUnit !== unitValue) {
          // Convert min value
          if (!isNaN(data.originalMin)) {
            const convertedMin = convertValue(data.originalMin, data.minUnit, unitValue);
            input.setAttribute('min', convertedMin);
          }
          
          // Convert max value
          if (!isNaN(data.originalMax)) {
            const convertedMax = convertValue(data.originalMax, data.maxUnit, unitValue);
            input.setAttribute('max', convertedMax);
          }
          
          // Convert current input value
          if (input.value && input.value.trim() !== '') {
            const currentValue = parseFloat(input.value);
            if (!isNaN(currentValue)) {
              const convertedValue = convertValue(currentValue, previousUnit, unitValue);
              input.value = convertedValue;
            }
          }
          
          // Update stored current unit
          data.currentUnit = unitValue;
        }
      }
    });
  }
  
  // Initialize: set current unit based on default checked radio
  const defaultUnitRadio = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
  const defaultUnit = defaultUnitRadio ? defaultUnitRadio.value : 'in';
  numberInputs.forEach(input => {
    const data = inputDataMap.get(input);
    if (data) {
      data.currentUnit = defaultUnit;
      // Set initial min/max based on default unit
      if (!isNaN(data.originalMin)) {
        const convertedMin = convertValue(data.originalMin, data.minUnit, defaultUnit);
        input.setAttribute('min', convertedMin);
      }
      if (!isNaN(data.originalMax)) {
        const convertedMax = convertValue(data.originalMax, data.maxUnit, defaultUnit);
        input.setAttribute('max', convertedMax);
      }
    }
  });
  
  // Initialize unit display
  updateInputUnits();
  
  // Handle radio change - visual update is handled by CSS and unit display
  unitRadios.forEach(radio => {
    radio.addEventListener('change', function() {
      updateInputUnits();
      // Update payment buttons state when unit changes
      updatePaymentButtonsState();
    });
  });
  
  // Allow clicking on the switch background or slider to toggle (for custom-size-form)
  const unitToggleSwitch = document.querySelector('#custom-size-form .unit-toggle-switch');
  if (unitToggleSwitch) {
    unitToggleSwitch.addEventListener('click', function(e) {
      // Only handle clicks on the switch background or slider, not on labels
      // Labels will trigger their associated radio buttons automatically via 'for' attribute
      if (e.target === unitToggleSwitch || e.target.classList.contains('unit-toggle-slider')) {
        e.preventDefault();
        e.stopPropagation();
        const currentChecked = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
        if (currentChecked && currentChecked.id === 'unit-in') {
          document.getElementById('unit-cm').checked = true;
          document.getElementById('unit-cm').dispatchEvent(new Event('change', { bubbles: true }));
        } else {
          document.getElementById('unit-in').checked = true;
          document.getElementById('unit-in').dispatchEvent(new Event('change', { bubbles: true }));
        }
      }
    });
  }

  // Prevent entering 'e', 'E', '+', '-' in number inputs and enforce min/max
  numberInputs.forEach(input => {
    input.addEventListener('keydown', function(e) {
      // Block 'e', 'E', '+', '-' keys
      if (e.key === 'e' || e.key === 'E' || e.key === '+' || e.key === '-') {
        e.preventDefault();
      }
    });
    
    // Also prevent paste of invalid characters
    input.addEventListener('paste', function(e) {
      const paste = (e.clipboardData || window.clipboardData).getData('text');
      if (/[eE+\-]/.test(paste)) {
        e.preventDefault();
      }
    });
    
    // Validate min and max values on input and blur (show error, don't auto-correct)
    input.addEventListener('input', function() {
      this.classList.remove('error-highlight');
      validateMinMax(this, false); // false = don't show notification while typing
      // Update payment buttons state when input changes
      updatePaymentButtonsState();
    });
    
    input.addEventListener('blur', function() {
      validateMinMax(this, true); // true = show notification on blur
      // Update payment buttons state when input loses focus
      updatePaymentButtonsState();
    });
  });
  
  // Function to validate min and max values (show error instead of auto-correcting)
  function validateMinMax(input, showNotification) {
    const min = parseFloat(input.getAttribute('min'));
    const max = parseFloat(input.getAttribute('max'));
    const value = parseFloat(input.value);
    
    if (input.value && input.value.trim() !== '' && !isNaN(value)) {
      const placeholder = input.placeholder || input.name.replace('properties[', '').replace(']', '');
      const checkedUnit = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
      const unitDisplay = checkedUnit && checkedUnit.value === 'cm' ? 'cm' : 'in';
      
      if ((!isNaN(min) && value < min) || (!isNaN(max) && value > max)) {
        input.classList.add('error-highlight');
        if (showNotification) {
          let errorMessage = `<strong>${placeholder}</strong>`;
          if (!isNaN(min) && !isNaN(max)) {
            // Both min and max exist, show range
            errorMessage += ` must be between <strong>${min} ${unitDisplay}</strong> and <strong>${max} ${unitDisplay}</strong>.`;
          } else if (!isNaN(min)) {
            // Only min exists
            errorMessage += ` must be at least <strong>${min} ${unitDisplay}</strong>.`;
          } else if (!isNaN(max)) {
            // Only max exists
            errorMessage += ` must be at most <strong>${max} ${unitDisplay}</strong>.`;
          }
          showErrorNotification(errorMessage);
        }
        return false;
      } else {
        input.classList.remove('error-highlight');
        return true;
      }
    }
    return true;
  }
  
  // Remove error highlight from unit toggle when user selects a unit
  const unitRadiosForValidation = document.querySelectorAll('input[name="properties[Measurement Unit]"]');
  unitRadiosForValidation.forEach(radio => {
    radio.addEventListener('change', function() {
      const unitToggle = document.querySelector('#custom-size-form .unit-toggle-switch');
      if (unitToggle) {
        unitToggle.classList.remove('error-highlight');
      }
      // Update payment buttons state when unit changes
      updatePaymentButtonsState();
    });
  });

  // Show error notification function
  function showErrorNotification(message) {
    // Remove existing error notification
    const existingError = document.querySelector('.size-validation-error');
    if (existingError) {
      existingError.remove();
    }

    // Create error notification element
    const errorDiv = document.createElement('div');
    errorDiv.className = 'size-validation-error';
    
    // Create content wrapper
    const contentDiv = document.createElement('div');
    contentDiv.className = 'size-validation-error-content';
    contentDiv.innerHTML = message;
    errorDiv.appendChild(contentDiv);
    
    // Create close button
    const closeButton = document.createElement('button');
    closeButton.className = 'size-validation-error-close';
    closeButton.innerHTML = '<svg t="1764224110077" class="icon" viewBox="0 0 1024 1024" version="1.1" xmlns="http://www.w3.org/2000/svg" p-id="4702" width="24" height="24"><path d="M872.802928 755.99406 872.864326 755.99406 872.864326 755.624646Z" fill="#000000" p-id="4703"></path><path d="M927.846568 511.997953c0-229.315756-186.567139-415.839917-415.838893-415.839917-229.329059 0-415.85322 186.524161-415.85322 415.839917 0 229.300406 186.524161 415.84094 415.85322 415.84094C741.278405 927.838893 927.846568 741.29836 927.846568 511.997953M512.007675 868.171955c-196.375529 0-356.172979-159.827125-356.172979-356.174002 0-196.374506 159.797449-356.157629 356.172979-356.157629 196.34483 0 356.144326 159.783123 356.144326 356.157629C868.152001 708.34483 708.352505 868.171955 512.007675 868.171955" fill="#000000" p-id="4704"></path><path d="M682.378947 642.227993 553.797453 513.264806 682.261267 386.229528c11.661597-11.514241 11.749602-30.332842 0.234337-41.995463-11.514241-11.676947-30.362518-11.765975-42.026162-0.222057L511.888971 471.195665 385.223107 344.130711c-11.602246-11.603269-30.393217-11.661597-42.025139-0.059352-11.603269 11.618619-11.603269 30.407544-0.059352 42.011836l126.518508 126.887922L342.137823 639.104863c-11.662621 11.543917-11.780301 30.305213-0.23536 41.96988 5.830799 5.89015 13.429871 8.833179 21.086248 8.833179 7.53972 0 15.136745-2.8847 20.910239-8.569166l127.695311-126.311801L640.293433 684.195827c5.802146 5.8001 13.428847 8.717546 21.056572 8.717546 7.599072 0 15.165398-2.917446 20.968567-8.659217C693.922864 672.681586 693.950494 653.889591 682.378947 642.227993" fill="#000000" p-id="4705"></path></svg>';
    closeButton.setAttribute('aria-label', 'Close');
    closeButton.onclick = function() {
      errorDiv.classList.add('hide');
      setTimeout(() => {
        if (errorDiv.parentNode) {
          errorDiv.parentNode.removeChild(errorDiv);
        }
      }, 300);
    };
    errorDiv.appendChild(closeButton);
    
    // Add to page
    document.body.appendChild(errorDiv);
    
    // Auto remove after 5 seconds
    setTimeout(() => {
      if (errorDiv.parentNode) {
        errorDiv.classList.add('hide');
        setTimeout(() => {
          if (errorDiv.parentNode) {
            errorDiv.parentNode.removeChild(errorDiv);
          }
        }, 300);
      }
    }, 5000);
  }

  // Validation function
  function validateForm(event) {
    // Remove previous error highlights
    document.querySelectorAll('.error-highlight').forEach(el => {
      el.classList.remove('error-highlight');
    });

    // Check if size is selected
    const selectedSize = document.querySelector('input[name="properties[Size]"]:checked');
    
    if (!selectedSize) {
      if (event) {
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
      }
      const sizeContainer = document.querySelector('.style-select-item-container');
      if (sizeContainer) {
        sizeContainer.style.border = '1px solid #ff0000';
        sizeContainer.style.borderRadius = '8px';
        sizeContainer.style.padding = '8px';
        setTimeout(() => {
          sizeContainer.style.border = '';
          sizeContainer.style.borderRadius = '';
          sizeContainer.style.padding = '';
        }, 3000);
      }
      showErrorNotification('Please select a <strong>size</strong>.');
      return false;
    }

    // If Custom Size is selected, validate all required custom inputs
    if (selectedSize.value === 'Custom Size') {
      const customInputs = document.querySelectorAll('#custom-size-form input[type="number"]');
      const unitRadio = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
      
      let isValid = true;
      let missingFields = [];
      let invalidInputs = [];

      // Check measurement unit
      if (!unitRadio) {
        isValid = false;
        missingFields.push('Measurement Unit');
        const unitToggle = document.querySelector('#custom-size-form .unit-toggle-switch');
        if (unitToggle) {
          unitToggle.classList.add('error-highlight');
        }
      }

      // Check all number inputs (required and optional)
      customInputs.forEach(input => {
        if (!input.disabled) {
          const isRequired = input.hasAttribute('required');
          const value = parseFloat(input.value);
          const min = parseFloat(input.getAttribute('min'));
          const max = parseFloat(input.getAttribute('max'));
          
          // Check required fields
          if (isRequired && (!input.value || input.value.trim() === '' || isNaN(value) || value <= 0)) {
            isValid = false;
            const placeholder = input.placeholder || input.name.replace('properties[', '').replace(']', '');
            missingFields.push(placeholder);
            invalidInputs.push(input);
            input.classList.add('error-highlight');
          }
          // Check min/max for fields with values (both required and optional)
          else if (input.value && input.value.trim() !== '' && !isNaN(value)) {
            if ((!isNaN(min) && value < min) || (!isNaN(max) && value > max)) {
              isValid = false;
              const placeholder = input.placeholder || input.name.replace('properties[', '').replace(']', '');
              const checkedUnit = document.querySelector('input[name="properties[Measurement Unit]"]:checked');
              const unitDisplay = checkedUnit && checkedUnit.value === 'cm' ? 'cm' : 'in';
              
              let rangeText = '';
              if (!isNaN(min) && !isNaN(max)) {
                // Both min and max exist, show range
                rangeText = `must be between ${min} and ${max} ${unitDisplay}`;
              } else if (!isNaN(min)) {
                // Only min exists
                rangeText = `must be at least ${min} ${unitDisplay}`;
              } else if (!isNaN(max)) {
                // Only max exists
                rangeText = `must be at most ${max} ${unitDisplay}`;
              }
              
              missingFields.push(`${placeholder} (${rangeText})`);
              invalidInputs.push(input);
              input.classList.add('error-highlight');
            }
          }
        }
      });

      if (!isValid) {
        if (event) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
        }
        // Scroll to first invalid input
        if (invalidInputs.length > 0) {
          invalidInputs[0].scrollIntoView({ behavior: 'smooth', block: 'center' });
        }
        // Format missing fields list
        let missingList;
        if (missingFields.length === 1) {
          missingList = missingFields[0];
        } else if (missingFields.length === 2) {
          missingList = missingFields.join(' and ');
        } else {
          missingList = missingFields.slice(0, -1).join(', ') + ', and ' + missingFields[missingFields.length - 1];
        }
        showErrorNotification(`Please fill in all required fields: <strong>${missingList}</strong>`);
        return false;
      }
    }
    
    return true;
  }

  // Form submission validation
  if (productForm) {
    productForm.addEventListener('submit', function(e) {
      if (!validateForm(e)) {
        // Prevent animation by removing any added classes and stopping fly-to-cart animation
        const addToCartButton = productForm.querySelector('button[ref="addToCartButton"]');
        if (addToCartButton) {
          addToCartButton.classList.remove('atc-added');
        }
        
        // Remove any fly-to-cart elements that might have been created
        const flyToCartElements = document.querySelectorAll('fly-to-cart');
        flyToCartElements.forEach(el => el.remove());
        
        return false;
      }
    });
  }

  // Function to add overlay to payment buttons
  function addPaymentButtonOverlay(button) {
    // Check if overlay already exists
    if (button.querySelector('.payment-button-overlay')) {
      return;
    }
    
    // Create overlay element
    const overlay = document.createElement('div');
    overlay.className = 'payment-button-overlay';
    overlay.style.cssText = `
      position: absolute;
      top: 0;
      left: 0;
      width: 100%;
      height: 100%;
      background-color: rgba(0, 0, 0, 0.05);
      cursor: not-allowed;
      z-index: 9999;
      display: flex;
      align-items: center;
      justify-content: center;
    `;
    
    // Make button container relative if not already
    const computedStyle = window.getComputedStyle(button);
    if (computedStyle.position === 'static') {
      button.style.position = 'relative';
    }
    
    // Add overlay to button
    button.appendChild(overlay);
    
    // Add click handler to overlay to show error
    overlay.addEventListener('click', function(e) {
      e.preventDefault();
      e.stopPropagation();
      e.stopImmediatePropagation();
      
      // Show error notification
      const fakeEvent = { preventDefault: function() {}, stopPropagation: function() {}, stopImmediatePropagation: function() {} };
      validateForm(fakeEvent);
    }, true);
  }
  
  // Function to remove overlay from payment buttons
  function removePaymentButtonOverlay(button) {
    const overlay = button.querySelector('.payment-button-overlay');
    if (overlay) {
      overlay.remove();
    }
  }
  
  // Function to disable payment buttons (including PayPal iframes)
  function disablePaymentButtons() {
    // Disable all dynamic checkout buttons
    const paymentButtons = document.querySelectorAll(
      '.shopify-payment-button, ' +
      '.sp-dynamic-checkout-button, ' +
      '.dynamic-checkout__content, ' +
      '[data-shopify="payment-button"], ' +
      'iframe[src*="paypal"], ' +
      'iframe[src*="checkout"], ' +
      '.shopify-paypal-button'
    );
    
    paymentButtons.forEach(btn => {
      // Add disabled class
      btn.classList.add('payment-button-disabled');
      // Add overlay to capture clicks and show errors
      addPaymentButtonOverlay(btn);
      // Visual feedback
      btn.style.opacity = '0.5';
      btn.style.cursor = 'not-allowed';
      
      // If it's an iframe, try to disable it
      if (btn.tagName === 'IFRAME') {
        try {
          btn.setAttribute('disabled', 'disabled');
        } catch (e) {
          // Cross-origin iframe, can't access
        }
      }
    });
  }
  
  // Function to enable payment buttons
  function enablePaymentButtons() {
    const paymentButtons = document.querySelectorAll('.payment-button-disabled');
    paymentButtons.forEach(btn => {
      btn.classList.remove('payment-button-disabled');
      // Remove overlay
      removePaymentButtonOverlay(btn);
      btn.style.opacity = '';
      btn.style.cursor = '';
      if (btn.tagName === 'IFRAME') {
        btn.removeAttribute('disabled');
      }
    });
  }

  // Function to check if element is a payment/checkout button
  function isPaymentOrCheckoutButton(element) {
    if (!element) return false;
    
    // Check if it's inside an iframe (PayPal buttons are often in iframes)
    if (element.tagName === 'IFRAME' || 
        (element.closest && element.closest('iframe'))) {
      const iframe = element.tagName === 'IFRAME' ? element : element.closest('iframe');
      if (iframe && iframe.src && (
          iframe.src.includes('paypal') || 
          iframe.src.includes('checkout') ||
          iframe.src.includes('payment'))) {
        return true;
      }
    }
    
    // Check element itself and all parents
    let current = element;
    while (current && current !== document.body) {
      // Check class names
      const classList = current.classList || [];
      if (classList.contains('shopify-payment-button__button') ||
          classList.contains('shopify-payment-button__button--unbranded') ||
          classList.contains('sp-dynamic-checkout-button') ||
          classList.contains('sp-dynamic-checkout-button-secondary') ||
          classList.contains('sp-dynamic-checkout-button-primary') ||
          classList.contains('shopify-paypal-button') ||
          classList.contains('dynamic-checkout__content') ||
          classList.contains('shopify-payment-button') ||
          classList.contains('buy-now-button') ||
          classList.contains('checkout-button')) {
        return true;
      }
      
      // Check data attributes
      if (current.getAttribute && (
          current.getAttribute('data-shopify') === 'payment-button' ||
          current.getAttribute('data-testid') === 'shopify-payment-button' ||
          current.getAttribute('data-testid') === 'dynamic-checkout-button')) {
        return true;
      }
      
      // Check if inside dynamic checkout container
      if (current.id && typeof current.id === 'string' && (
          current.id.includes('dynamic-checkout') ||
          current.id.includes('shopify-payment-button'))) {
        return true;
      }
      
      current = current.parentElement;
    }
    
    return false;
  }

  // Function to check if element is an add to cart button
  function isAddToCartButton(element) {
    if (!element) return false;
    
    let current = element;
    while (current && current !== document.body) {
      const classList = current.classList || [];
      if (classList.contains('add-to-cart-button') ||
          classList.contains('add-to-cart-text--added') ||
          classList.contains('add-to-cart-icon--added') ||
          classList.contains('atc-button')) {
        return true;
      }
      
      if (current.id === 'addToCart' ||
          (current.id && typeof current.id === 'string' && current.id.includes('add-to-cart')) ||
          current.getAttribute('ref') === 'addToCartButton') {
        return true;
      }
      
      if (current.tagName === 'BUTTON' && current.type === 'submit' && 
          current.closest && current.closest('form.shopify-product-form')) {
        return true;
      }
      
      current = current.parentElement;
    }
    
    return false;
  }

  // Track if we've already shown error for this interaction to avoid duplicates
  let errorShownForInteraction = false;
  let lastInteractionTime = 0;
  
  // Intercept pointerdown events first (earliest possible)
  document.addEventListener('pointerdown', function(event) {
    const target = event.target;
    if (!target) return;
    
    const isPaymentButton = isPaymentOrCheckoutButton(target);
    const isAddToCart = isAddToCartButton(target);
    
    if (isPaymentButton || isAddToCart) {
      const currentTime = Date.now();
      // Reset error flag if it's a new interaction (more than 500ms since last)
      if (currentTime - lastInteractionTime > 500) {
        errorShownForInteraction = false;
      }
      lastInteractionTime = currentTime;
      
      // For payment buttons, show error immediately since click might not fire
      if (isPaymentButton && !errorShownForInteraction) {
        if (!validateForm(event)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          disablePaymentButtons();
          errorShownForInteraction = true;
          return false;
        } else {
          enablePaymentButtons();
        }
      } else if (isAddToCart) {
        // For add to cart, just prevent but don't show error (will show on click)
        const fakeEvent = { preventDefault: function() {}, stopPropagation: function() {}, stopImmediatePropagation: function() {} };
        if (!validateForm(fakeEvent)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          return false;
        }
      }
    }
  }, true);
  
  // Intercept touchstart events (for mobile)
  document.addEventListener('touchstart', function(event) {
    const target = event.target;
    if (!target) return;
    
    const isPaymentButton = isPaymentOrCheckoutButton(target);
    const isAddToCart = isAddToCartButton(target);
    
    if (isPaymentButton || isAddToCart) {
      const currentTime = Date.now();
      if (currentTime - lastInteractionTime > 500) {
        errorShownForInteraction = false;
      }
      lastInteractionTime = currentTime;
      
      // For payment buttons, show error immediately since click might not fire
      if (isPaymentButton && !errorShownForInteraction) {
        if (!validateForm(event)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          disablePaymentButtons();
          errorShownForInteraction = true;
          return false;
        } else {
          enablePaymentButtons();
        }
      } else if (isAddToCart) {
        const fakeEvent = { preventDefault: function() {}, stopPropagation: function() {}, stopImmediatePropagation: function() {} };
        if (!validateForm(fakeEvent)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          return false;
        }
      }
    }
  }, true);
  
  // Also intercept mousedown events (some buttons use mousedown instead of click)
  document.addEventListener('mousedown', function(event) {
    const target = event.target;
    if (!target) return;
    
    const isPaymentButton = isPaymentOrCheckoutButton(target);
    const isAddToCart = isAddToCartButton(target);
    
    if (isPaymentButton || isAddToCart) {
      const currentTime = Date.now();
      if (currentTime - lastInteractionTime > 500) {
        errorShownForInteraction = false;
      }
      lastInteractionTime = currentTime;
      
      // For payment buttons, show error immediately since click might not fire
      if (isPaymentButton && !errorShownForInteraction) {
        if (!validateForm(event)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          disablePaymentButtons();
          errorShownForInteraction = true;
          return false;
        } else {
          enablePaymentButtons();
        }
      } else if (isAddToCart) {
        const fakeEvent = { preventDefault: function() {}, stopPropagation: function() {}, stopImmediatePropagation: function() {} };
        if (!validateForm(fakeEvent)) {
          event.preventDefault();
          event.stopPropagation();
          event.stopImmediatePropagation();
          return false;
        }
      }
    }
  }, true);
  
  // Button click validation - use capture phase with higher priority
  // This is where we show error messages for Add to Cart buttons
  // Payment buttons show error in mousedown/pointerdown to ensure it's shown
  document.addEventListener('click', function(event) {
    const target = event.target;
    if (!target) return;
    
    // Check if it's a payment/checkout button or add to cart button
    const isPaymentButton = isPaymentOrCheckoutButton(target);
    const isAddToCart = isAddToCartButton(target);
    
    if (isAddToCart) {
      // Validate form - this will show error notification if validation fails
      if (!validateForm(event)) {
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
        
        // Prevent animation by removing any added classes and stopping fly-to-cart animation
        const addToCartButton = document.querySelector('button[ref="addToCartButton"]') ||
                               document.querySelector('.add-to-cart-button') ||
                               document.querySelector('#addToCart');
        if (addToCartButton) {
          addToCartButton.classList.remove('atc-added');
        }
        
        // Remove any fly-to-cart elements that might have been created
        const flyToCartElements = document.querySelectorAll('fly-to-cart');
        flyToCartElements.forEach(el => el.remove());
        
        // Use requestAnimationFrame to ensure cleanup happens after any potential animation start
        requestAnimationFrame(() => {
          if (addToCartButton) {
            addToCartButton.classList.remove('atc-added');
          }
          const flyToCartElements = document.querySelectorAll('fly-to-cart');
          flyToCartElements.forEach(el => el.remove());
        });
        
        return false;
      }
    } else if (isPaymentButton) {
      // For payment buttons, validate again in case click event fired
      // But don't show error again if we already showed it
      const currentTime = Date.now();
      if (currentTime - lastInteractionTime > 500) {
        errorShownForInteraction = false;
      }
      
      if (!errorShownForInteraction && !validateForm(event)) {
        event.preventDefault();
        event.stopPropagation();
        event.stopImmediatePropagation();
        disablePaymentButtons();
        errorShownForInteraction = true;
        return false;
      } else if (validateForm(event)) {
        enablePaymentButtons();
      }
    }
  }, true); // Use capture phase to catch events early
  
  // Intercept form submissions from dynamic checkout (they might submit directly)
  if (productForm) {
    // Override submit method
    const originalSubmit = productForm.submit;
    productForm.submit = function() {
      const fakeEvent = { preventDefault: function() {}, stopPropagation: function() {}, stopImmediatePropagation: function() {} };
      if (!validateForm(fakeEvent)) {
        return false;
      }
      return originalSubmit.call(this);
    };
    
    // Also listen for submit events (in case they use dispatchEvent)
    productForm.addEventListener('submit', function(e) {
      if (!validateForm(e)) {
        e.preventDefault();
        e.stopPropagation();
        e.stopImmediatePropagation();
        return false;
      }
    }, true); // Use capture phase
  }
});
</script>
