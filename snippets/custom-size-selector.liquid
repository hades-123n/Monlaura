      {%- assign cm_data = "US00|US00:77.5:59.5:85.5:145,US0|US0:80:62:88.5:145,US2|US2:82.5:65:91:147,US4|US4:85:67.5:93.5:147,US6|US6:87.5:70:96:150,US8|US8:90:72.5:98.5:150,US10|US10:92.5:75:101:152,US12|US12:96.5:78.5:105:152,US14|US14:100.5:82.5:108.5:155,US16|US16:104:86.5:112.5:155,US16W|US16W:109:92:115.5:155,US18W|US18W:114.5:98:120.5:155,US20W|US20W:119.5:103.5:125.5:155,US22W|US22W:124.5:109:131:155,US24W|US24W:129.5:115:136:155,US26W|US26W:134.5:120.5:141:155,US28W|US28W:139.5:125.5:146:155,US30W|US30W:146:132:152.5:155,US32W|US32W:153.5:139.5:160:155" | split: ',' -%}
    {%- elsif size_type == 'flower_girl_size' -%}
