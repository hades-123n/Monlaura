    {%- elsif size_type == 'mens_rings_size' or size_type == 'womens_rings_size' -%}
      {%- assign table_headers = "Our Size,US Size,Circumference,Diameter" | split: ',' -%}
      {%- assign inch_data = "R5|R5:US5:19.42:6.18,R6|R6:US6:20.41:6.5,R7|R7:US7:21.39:6.81,R8|R8:US8:22.51:7.17,R9|R9:US9:23.37:7.44,R10|R10:US10:24.49:7.8,R11|R11:US11:25.48:8.11,R12|R12:US12:26.34:8.39,R13|R13:US13:27.46:8.74" | split: ',' -%}
      {%- assign cm_data = "R5|R5:US5:49.32:15.7,R6|R6:US6:51.83:16.5,R7|R7:US7:54.34:17.3,R8|R8:US8:57.17:18.2,R9|R9:US9:59.37:18.9,R10|R10:US10:62.2:19.8,R11|R11:US11:64.71:20.6,R12|R12:US12:66.91:21.3,R13|R13:US13:69.74:22.2" | split: ',' -%}
    {%- elsif size_type == 'shoes_size' -%}
      {%- assign table_headers = "Our Size,EU,US,UK,CN,Foot Length,Foot Width" | split: ',' -%}
      {%- assign inch_data = "S35|S35:35:5:3:225:8.7-8.8:3.3,S36|S36:36:6:4:230:9.0-9.1:3.3-3.5,S37|S37:37:6.5-7:4.5-5:235:9.2-9.3:3.5,S38|S38:38:7.5:5.5:240:9.5-9.6:3.5-3.7,S39|S39:39:8.5:6.5:250:9.7-9.8:3.7,S40|S40:40:9:7.5-8:255:10.0-10.1:3.7-3.9,S41|S41:41:9.5-10:8.5:260:10.3-10.4:3.9,S42|S42:42:10.5:9.5:270:10.6-10.7:3.9-4.1,S43|S43:43:11.5-12:10:275:10.8-11:4.1-4.3" | split: ',' -%}
