{% comment %}Updated at 20251224{% endcomment %}
{%- assign product_form_id = 'product-form-' | append: section.id -%}
{%- assign measurement_img_small = 'how-to-measure-01.jpg' -%}
{%- assign measurement_img_large = 'how-to-measure-02.jpg' -%}

{%- assign tags_lower = product.tags | handle -%}
{%- assign size_type = '' -%}
{%- assign default_unit = 'inch' -%}
{%- if tags_lower contains 'womens-rings-size' or tags_lower contains 'women-s-rings-size' -%}
  {%- assign size_type = 'womens_rings_size' -%}
{%- elsif tags_lower contains 'mens-rings-size' or tags_lower contains 'men-s-rings-size' -%}
  {%- assign size_type = 'mens_rings_size' -%}
{%- elsif tags_lower contains 'flower-girl-new-size' or tags_lower contains 'flower-girl02' -%}
  {%- assign size_type = 'flower_girl_new_size' -%}
  {%- assign default_unit = 'inch' -%}
{%- elsif tags_lower contains 'flower-girl-size' -%}
  {%- assign size_type = 'flower_girl_size' -%}
{%- elsif tags_lower contains 'junior-bridesmaid-size' -%}
  {%- assign size_type = 'junior_bridesmaid_size' -%}
{%- elsif tags_lower contains 'shoes-size' or tags_lower contains 'shoes-size-for-women' -%}
  {%- assign size_type = 'shoes_size' -%}
{%- elsif tags_lower contains 'boy-suits-size' -%}
  {%- assign size_type = 'boy_suits_size' -%}
{%- elsif tags_lower contains 'jacket-size' or tags_lower contains 'jacket-wraps-size' -%}
  {%- assign size_type = 'jacket_size' -%}
{%- elsif tags_lower contains 'vest-size' -%}
  {%- assign size_type = 'vest_size' -%}
{%- elsif tags_lower contains 'mens-pants-size' or tags_lower contains 'men-s-pants-size' -%}
  {%- assign size_type = 'mens_pants_size' -%}
{%- elsif tags_lower contains 'shapewear-size' -%}
  {%- assign size_type = 'shapewear_size' -%}
{%- elsif tags_lower contains 'shirt-size' -%}
  {%- assign size_type = 'shirt_size' -%}
{%- elsif tags_lower contains 'instock-suits-size' -%}
  {%- assign size_type = 'instock_suits_size' -%}
{%- elsif tags_lower contains 'suits size' -%}
  {%- assign size_type = 'suits_size' -%}
{%- elsif tags_lower contains 'womens-dress-size' -%}
  {%- assign size_type = 'womens_dress_size' -%}
{%- elsif tags_lower contains 'general-plus-size' -%}
  {%- assign size_type = 'general_plus_size' -%}
{%- elsif tags_lower contains 'general-size' or tags_lower contains 'size-option' or tags_lower contains 'general-size-short' -%}
  {%- assign size_type = 'general_size' -%}
{%- endif -%}

{%- if size_type != '' -%}
<div class="shopify-size-selector" data-size-type="{{ size_type }}">
  <div class="size-option-name">
    <span class="size-label"><strong>Size:</strong> <span id="size-select-size">Select Size</span></span>
    <span id="size-chart-label" class="pretty-modal" data-modal-id="size-chart-value">Size Chart</span>
  </div>
  <div class="style-select-item-container">
    {%- if size_type == 'general_size' -%}
      {%- assign sizes = "Custom Size,US00,US0,US2,US4,US6,US8,US10,US12,US14,US16,US16W,US18W,US20W,US22W,US24W,US26W,US28W" | split: ',' -%}
    {%- elsif size_type == 'general_plus_size' -%}
      {%- assign sizes = "US12,US14,US16,US16W,US18W,US20W,US22W,US24W,US26W,US28W,Custom Size" | split: ',' -%}
    {%- elsif size_type == 'flower_girl_size' -%}
      {%- assign sizes = "Custom Size,C2,C3,C4,C5,C6,C7,C8,C10,C12,C14" | split: ',' -%}
    {%- elsif size_type == 'flower_girl_new_size' -%}
      {%- assign sizes = "Custom Size,2Y,3Y,4Y,5Y,6Y,7Y,8Y,10Y,12Y,14Y" | split: ',' -%}
    {%- elsif size_type == 'junior_bridesmaid_size' -%}
      {%- assign sizes = "Custom Size,J4,J6,J8,J10,J12,J14,J16" | split: ',' -%}
    {%- elsif size_type == 'shoes_size' -%}
      {%- assign sizes = "S36,S37,S38,S39,S40,S41,S42" | split: ',' -%}
    {%- elsif size_type == 'womens_dress_size' -%}
      {%- assign sizes = "XXXS,XXS,XS,S,M,L,XL,2XL,3XL,4XL" | split: ',' -%}
    {%- elsif size_type == 'instock_suits_size' -%}
      {%- assign sizes = "2XS,S,M,L,XL,2XL,3XL,4XL,5XL" | split: ',' -%}
    {%- elsif size_type == 'suits_size' -%}
      {%- assign sizes = "Custom Size,XS,S,M,L,XL,2XL,3XL,4XL,5XL" | split: ',' -%}
    {%- elsif size_type == 'womens_rings_size' -%}
      {%- assign sizes = "R5,R5.5,R6,R6.5,R7,R7.5,R8,R8.5,R9,R9.5,R10,R10.5,R11" | split: ',' -%}
    {%- elsif size_type == 'mens_rings_size' -%}
      {%- assign sizes = "R7,R7.5,R8,R8.5,R9,R9.5,R10,R10.5,R11,R11.5,R12,R12.5,R13" | split: ',' -%}
    {%- elsif size_type == 'jacket_size' -%}
      {%- assign sizes = "Custom Size,US2,US4,US6,US8,US10,US12,US14,US16,US16W,US18W,US20W,US22W,US24W,US26W" | split: ',' -%}
    {%- elsif size_type == 'vest_size' -%}
      {%- assign sizes = "XS,S,M,L,XL,2XL,3XL,4XL,5XL,6XL" | split: ',' -%}
    {%- elsif size_type == 'mens_pants_size' -%}
      {%- assign sizes = "XS,S,M,L,XL,2XL,3XL,4XL,5XL" | split: ',' -%}
    {%- elsif size_type == 'boy_suits_size' -%}
      {%- assign sizes = "BS100,BS110,BS120,BS130,BS140,BS150" | split: ',' -%}
    {%- elsif size_type == 'shapewear_size' -%}
      {%- assign sizes = "S,M,L,XL,2XL" | split: ',' -%}
    {%- elsif size_type == 'shirt_size' -%}
      {%- assign sizes = "S,M,L,XL,2XL" | split: ',' -%}
    {%- endif -%}
    {% for sz in sizes %}
      <label class="style-select-item {{ sz | handle }}-select-item">
        <input type="radio" name="properties[Size]" value="{{ sz }}" form="{{ product_form_id }}" hidden>
        <span>{{ sz }}</span>
      </label>
    {% endfor %}
  </div>

  <!-- Size Chart -->
  <div id="size-chart-table" style="display:none; margin-top:10px;">
    <!-- Chart Unit Toggle Switch -->
    <div class="unit-toggle-container" style="margin-bottom:10px;">
      <input type="radio" name="chart-unit" value="inch" id="chart-unit-in" hidden {% if default_unit == 'inch' %}checked{% endif %}>
      <input type="radio" name="chart-unit" value="cm" id="chart-unit-cm" hidden {% if default_unit == 'cm' %}checked{% endif %}>
      <div class="unit-toggle-switch chart-unit-toggle">
        <label class="unit-toggle-label" for="chart-unit-in">INCH</label>
        <span class="unit-toggle-slider"></span>
        <label class="unit-toggle-label" for="chart-unit-cm">CM</label>
      </div>
    </div>

