<style>
  .custom-discount-tips {
    width: 100%;
    margin: 1rem 0;
  }

  .discount-tips-container {
    background: #f5f0e8; /* Light beige background */
    border-radius: 0.5rem;
    padding: 0.5rem;
    display: flex;
    align-items: center;
    justify-content: space-around;
    gap: 0;
    flex-wrap: nowrap;
    overflow: hidden;
    max-width: 100%;
    box-sizing: border-box;
  }

  .discount-offer {
    background: #ffffff;
    border-radius: 0.25rem;
    padding: 0.5rem;
    flex: 1 1 calc(33.333% - 0.5rem); /* Set flex-basis to approximately 1/3 width to ensure uniform wrapping */
    display: flex;
    flex-direction: row;
    align-items: center;
    justify-content: space-between;
    gap: 1px;
    position: relative;
    min-width: 0; /* Allow flex items to shrink below content size */
    overflow: hidden;
    max-width: 100%;
    box-sizing: border-box;
  }

  .discount-left {
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: 0.15rem;
    flex-shrink: 0; /* Prevent left section from shrinking */
    min-width: 0;
    max-width: 100%;
    min-width: 60px;
  }

  .discount-percentage {
    color: #b86b0b; /* Warm orange-brown color */
    font-size: 1rem;
    font-weight: 600;
    line-height: 1.1;
    white-space: nowrap;
  }

  .discount-threshold {
    color: #999999; /* Light gray */
    font-size: 0.65rem;
    line-height: 1.1;
    white-space: nowrap;
  }

  .custom-discount-coupon {
    display: flex;
    align-items: center;
    gap: 0.2rem;
    border: 1.5px dashed #b86b0b; /* Dashed orange-brown border */
    border-radius: 0.2rem;
    padding: 1px 2px;
    flex-shrink: 0;
    white-space: nowrap;
    min-width: 70px; /* Set uniform minimum width to ensure consistent wrapping behavior */
    cursor: pointer;
    user-select: none;
    transition: opacity 0.2s ease;
  }

  .custom-discount-coupon:hover {
    opacity: 0.7;
  }

  .coupon-scissors {
    color: #b86b0b;
    display: inline-block;
    flex-shrink: 0;
    width: 12px;
    height: 12px;
  }

  .discount-coupon-code {
    color: #000000;
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.02em;
  }

  .discount-divider {
    width: 1px;
    height: 60%;
    background: #d6d6d6;
    flex-shrink: 0;
    margin: 0 0.25rem;
  }

  /* Responsive design */
  @media (min-width: 768px) and (max-width: 1039px) {
    .discount-offer {
      flex-wrap: wrap;
    }
  }
  @media (max-width: 767px) {
    .custom-discount-tips {
      overflow: hidden;
    }

    .discount-tips-container {
      padding: 0.75rem;

      transform-origin: center;
      width: 100%;
    }

    .discount-offer {
      padding: 0.75rem;
      gap: 0.5rem;
    }

    .discount-percentage {
      font-size: 1.25rem;
    }

    .discount-threshold {
      font-size: 0.7rem;
    }

    .discount-coupon {
      padding: 0.3rem 0.5rem;
    }

    .discount-coupon-code {
      font-size: 0.75rem;
    }

    .coupon-scissors {
