<script>
  document.addEventListener('DOMContentLoaded', function () {
    const toast = document.createElement('div');
    toast.className = 'copy-toast';
    toast.textContent = 'Copied, use it at checkout page.';
    document.body.appendChild(toast);

    const couponElements = document.querySelectorAll('.custom-discount-coupon');

    couponElements.forEach(function (couponElement) {
      couponElement.addEventListener('click', function () {
        const codeElement = this.querySelector('.discount-coupon-code');
        if (!codeElement) return;

        const couponCode = codeElement.textContent.trim();

        if (navigator.clipboard && navigator.clipboard.writeText) {
          navigator.clipboard.writeText(couponCode).then(function () {
            showToast();
          }).catch(function () {
            fallbackCopyToClipboard(couponCode);
          });
        } else {
          fallbackCopyToClipboard(couponCode);
        }
      });
    });

    function showToast() {
      toast.classList.add('show');
      setTimeout(function () {
        toast.classList.remove('show');
      }, 3000);
    }

    function fallbackCopyToClipboard(text) {
      const textArea = document.createElement('textarea');
      textArea.value = text;
      textArea.style.position = 'fixed';
      textArea.style.left = '-999999px';
      textArea.style.top = '-999999px';
      document.body.appendChild(textArea);
      textArea.focus();
      textArea.select();

      try {
        document.execCommand('copy');
        showToast();
      } catch (err) {
        console.error('Failed to copy text: ', err);
      }

      document.body.removeChild(textArea);
    }
  });
</script>