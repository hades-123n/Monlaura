<script>
  const STORE_NAME = '{{ shop.permanent_domain }}';
  const API_BASE = 'https://reviews-plus.lightingrid.com';

  const PAGE_LIMIT = 12;
const EXCLUDED_REVIEW_IDS = [1203475468];
  let currentPage = 1;
  let isLoading = false;
  let hasMore = true;
  let currentType = 'all';
  let dynamicCategories = [];
  let currentCategoryKey = null;
  let allReviewsData = [];
  let currentVisibleReviews = [];
  let currentModalIndex = -1;
  let scrollThrottle = false;

  // 产品信息缓存（仅用于降级）
  const productInfoCache = {};

  // ========== 工具函数 ==========
  function renderStars(rating) {
    const full = Math.floor(rating);
    const half = rating % 1 >= 0.5;
    let stars = '';
    for (let i = 0; i < full; i++) stars += '<span class="star">★</span>';
    if (half) stars += '<span class="star">½</span>';
    for (let i = full + (half ? 1 : 0); i < 5; i++) stars += '<span class="star-empty">★</span>';
    return stars;
  }

  function getProductUrl(handle) {
    if (!handle) return '#';
    return `https://${STORE_NAME}/products/${handle}`;
  }

  function getReviewImage(review) {
    if (!review.pictures || !review.pictures.length) return null;
    const first = review.pictures[0];
    const url = first.urls?.original || first.original || first.url || (typeof first === 'string' ? first : null);
    return url && url.startsWith('http') ? url : null;
  }

  function escapeHtml(str) {
    if (!str) return '';
    return str.replace(/[&<>]/g, (m) => {
      if (m === '&') return '&amp;';
      if (m === '<') return '&lt;';
      if (m === '>') return '&gt;';
      return m;
    });
  }

  // 降级方案：通过 handle 获取产品信息（仅在 API 未提供 product_image/price 时使用）
  async function fetchProductInfoByHandle(handle) {
    if (!handle) return null;
    if (productInfoCache[handle]) return productInfoCache[handle];
    try {
      const response = await fetch(`/products/${handle}.js`);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const product = await response.json();
      const info = {
        title: product.title,
        imageUrl: product.featured_image || '',
        price: product.price ? `$${parseFloat(product.price).toFixed(2)}` : '',
      };
      productInfoCache[handle] = info;
      return info;
    } catch (error) {
      console.error(`Failed to fetch product info for handle ${handle}:`, error);
      return null;
    }
  }

  function showEmptyStateCard(message, isError = false) {
    const container = document.getElementById('reviews-grid');
    container.classList.remove('skeleton-loading');
    container.innerHTML = `<div class="empty-state-card ${isError ? 'error' : ''}">${escapeHtml(message)}</div>`;
  }

  function showErrorOnSkeleton(message) {
    const container = document.getElementById('reviews-grid');
    const existingError = container.querySelector('.skeleton-error-card');
    if (existingError) existingError.remove();
    const errorCard = document.createElement('div');
    errorCard.className = 'skeleton-error-card';
    errorCard.style.cssText =
      'grid-column: 1 / -1; text-align: center; padding: 20px; background: #fff; border-radius: 12px; margin-bottom: 20px; color: #000;';
    errorCard.innerHTML = ` ${escapeHtml(message)}`;
    container.insertBefore(errorCard, container.firstChild);
  }

  function removeSkeletonErrorCard() {
    const container = document.getElementById('reviews-grid');
    const errorCard = container.querySelector('.skeleton-error-card');
    if (errorCard) errorCard.remove();
  }

  function appendErrorMessage(message, onRetry) {
    const container = document.getElementById('reviews-grid');
    const existingError = container.querySelector('.error-toast');
    if (existingError) existingError.remove();
    const errorDiv = document.createElement('div');
    errorDiv.className = 'error-toast';
    errorDiv.innerHTML = `
      <div style="display: flex; justify-content: space-between; align-items: center; background: #fff3f3; padding: 12px 16px; border-radius: 8px; margin: 20px 0; box-shadow: 0 1px 4px rgba(0,0,0,0.1);">
        <span style="color: #d32f2f;">⚠️ ${escapeHtml(message)}</span>
        <div>
          <button class="retry-btn" style="background: #3d4754; color: white; border: none; padding: 6px 16px; border-radius: 20px; cursor: pointer; margin-right: 10px;">Retry</button>
          <button class="close-error" style="background: none; border: none; font-size: 20px; cursor: pointer;">&times;</button>
        </div>
      </div>
    `;
    container.appendChild(errorDiv);
    errorDiv.querySelector('.retry-btn').addEventListener('click', () => {
      errorDiv.remove();
      if (onRetry) onRetry();
    });
    errorDiv.querySelector('.close-error').addEventListener('click', () => {
      errorDiv.remove();
    });
  }

  // ========== 模态框内容更新 ==========
  async function updateModalContent(index) {
    if (!currentVisibleReviews.length || index < 0 || index >= currentVisibleReviews.length) return;
    const review = currentVisibleReviews[index];
    if (!review) return;

    // 评论图片部分
    let allImages = [];
    if (review.pictures && Array.isArray(review.pictures)) {
      allImages = review.pictures
        .map((p) => p.urls?.original || p.original || p.url || (typeof p === 'string' ? p : null))
        .filter((url) => url && url.startsWith('http'));
    }
    if (allImages.length === 0) allImages = ['https://via.placeholder.com/600x600?text=No+Image'];

    const mainImg = document.getElementById('myModalImage');
    const thumbnailsContainer = document.getElementById('myModalThumbnails');
    let currentImgIndex = 0;
    mainImg.src = allImages[0];

    thumbnailsContainer.innerHTML = '';
    allImages.forEach((imgUrl, idx) => {
      const thumb = document.createElement('img');
      thumb.src = imgUrl;
      thumb.className = 'myModal-thumbnail';
      if (idx === currentImgIndex) thumb.classList.add('active');
      thumb.addEventListener('click', () => {
        mainImg.src = imgUrl;
        document.querySelectorAll('.myModal-thumbnail').forEach((t, i) => {
          if (i === idx) t.classList.add('active');
          else t.classList.remove('active');
        });
        currentImgIndex = idx;
      });
      thumbnailsContainer.appendChild(thumb);
    });
    thumbnailsContainer.style.display = allImages.length <= 1 ? 'none' : 'flex';

    // 评论文字信息（不含产品标题）
    document.getElementById('myModalRating').innerHTML = renderStars(review.rating || 0);
    document.getElementById('myModalReviewer').textContent = `By ${review.reviewer?.name || 'Anonymous'}`;
    document.getElementById('myModalBody').textContent = review.body || '';
    document.getElementById('myModalDate').textContent = review.created_at
      ? new Date(review.created_at).toLocaleDateString()
      : '';

    // 产品信息：链接、图片、标题、价格
    const productLinkElem = document.getElementById('myModalProductLink');
    const productImgElem = document.getElementById('myModalProductImage');
    const productTitleElem = document.getElementById('myModalProduct');
    const priceElem = document.getElementById('myModalPrice');

    const productHandle = review.product_handle || '';
    const productTitle = review.product_title || 'Product';
    let productUrl = getProductUrl(productHandle);

    // 优先使用 API 返回的产品图片和价格
    let productImage = review.product_image || null;
    let productPrice = review.product_price || null;

    // 如果 API 缺少图片或价格，尝试降级获取（仅当没有时才请求，避免过多请求）
    let info = null;
    if ((!productImage || !productPrice) && productHandle) {
      info = await fetchProductInfoByHandle(productHandle);
      if (info) {
        if (!productImage) productImage = info.imageUrl;
        if (!productPrice) productPrice = info.price;
      }
    }

    // 更新外层链接（产品图片和标题共用此链接）
    productLinkElem.href = productUrl;

    // 产品图片
   if (productImage) {
  productImgElem.src = productImage;
  productImgElem.style.display = 'block';
} else {
  productImgElem.src = '';          // 清空 src，阻止缓存泄露
  productImgElem.style.display = 'none';
}

    productTitleElem.innerText = productTitle;

    function formatPrice(priceStr) {
      if (!priceStr) return '';
      const raw = String(priceStr).trim();
      // 提取字符串中的数字部分（支持整数或小数）
      const match = raw.match(/(\d+(?:\.\d+)?)/);
      if (!match) return raw; // 没有数字，返回原字符串

      let num = parseFloat(match[1]);
      if (isNaN(num)) return raw;

      // 如果原始字符串不含小数点且数值较大（认为是分单位），则除以100
      // console.log(num, raw, 'cj');

      if (!raw.includes('.') && num > 10000) {
        num = num / 100;
        // console.log(`$${num}/100`, num, 001);
      }
      if (num >= 10000) {
        num = num / 100;
        return `$${num.toFixed(2)}`;
      }

      return `$${num.toFixed(2)}`;
    }

    priceElem.textContent = formatPrice(productPrice);

    // 左右按钮禁用状态
    const prevBtn = document.querySelector('.modal-prev');
    const nextBtn = document.querySelector('.modal-next');
    if (prevBtn) index <= 0 ? prevBtn.setAttribute('disabled', 'disabled') : prevBtn.removeAttribute('disabled');
    if (nextBtn)
      index >= currentVisibleReviews.length - 1
        ? nextBtn.setAttribute('disabled', 'disabled')
        : nextBtn.removeAttribute('disabled');
  }

  function openModalWithReview(review, index) {
    if (!review) return;
    currentModalIndex = index;
    updateModalContent(currentModalIndex);
    const modal = document.getElementById('reviewmyModal');
    if (modal) modal.style.display = 'block';
  }

  // ========== 图片网格渲染 ==========
  function renderGridFull(reviews) {
    const container = document.getElementById('reviews-grid');
    const reviewsWithImage = reviews.filter((r) => getReviewImage(r) !== null);
    currentVisibleReviews = reviewsWithImage;
    if (reviewsWithImage.length === 0) {
      showEmptyStateCard('No customer images found for this category.', false);
      return;
    }
    let html = '';
    reviewsWithImage.forEach((review, idx) => {
      let imgUrl = getReviewImage(review);
      if (!imgUrl) imgUrl = 'https://via.placeholder.com/600x800?text=No+Image';
      html += `<div class="review-card" data-index="${idx}">
                <img class="review-card-image" src="${escapeHtml(imgUrl)}" alt="${escapeHtml(
        review.product_title || 'Product'
      )}" loading="lazy">
              </div>`;
    });
    container.innerHTML = html;
    container.classList.remove('skeleton-loading');
    document.querySelectorAll('.review-card').forEach((card) => {
      card.addEventListener('click', (e) => {
        const idx = parseInt(card.getAttribute('data-index'), 10);
        const review = currentVisibleReviews[idx];
        if (review) openModalWithReview(review, idx);
      });
    });
  }

  function appendGridCards(newReviews) {
    const container = document.getElementById('reviews-grid');
    const newWithImage = newReviews.filter((r) => getReviewImage(r) !== null);
    if (newWithImage.length === 0) return;
    const startIndex = currentVisibleReviews.length;
    currentVisibleReviews = [...currentVisibleReviews, ...newWithImage];
    let html = '';
    newWithImage.forEach((review, idx) => {
      let imgUrl = getReviewImage(review);
      if (!imgUrl) imgUrl = 'https://via.placeholder.com/600x800?text=No+Image';
      const globalIndex = startIndex + idx;
      html += `<div class="review-card" data-index="${globalIndex}">
                <img class="review-card-image" src="${escapeHtml(imgUrl)}" alt="${escapeHtml(
        review.product_title || 'Product'
      )}" loading="lazy">
              </div>`;
    });
    container.insertAdjacentHTML('beforeend', html);
    container.querySelectorAll('.review-card').forEach((card) => {
      if (card.dataset.listener) return;
      card.dataset.listener = 'true';
      const idxAttr = card.getAttribute('data-index');
      if (idxAttr !== null) {
        card.addEventListener('click', () => {
          const idx = parseInt(idxAttr, 10);
          const review = currentVisibleReviews[idx];
          if (review) openModalWithReview(review, idx);
        });
      }
    });
  }

  // ========== 请求评论 ==========
  async function fetchReviewsByType(type, page = 1, append = false) {
  if (isLoading) return;

  isLoading = true;

  const container = document.getElementById('reviews-grid');

  if (!append) {
    container.classList.add('skeleton-loading');
    container.innerHTML = Array(12)
      .fill()
      .map(() => `<div class="skeleton-card"><div class="skeleton-image"></div></div>`)
      .join('');

    removeSkeletonErrorCard();

    currentPage = 1;
    hasMore = true;
    currentType = type;
    allReviewsData = [];
    currentVisibleReviews = [];
  }

  const url = `${API_BASE}/api/reviews-by-product-type?store=${STORE_NAME}&page=${page}&type=${encodeURIComponent(
    type
  )}`;

  try {
    const response = await fetch(url);

    if (!response.ok) throw new Error(`HTTP ${response.status}`);

    const result = await response.json();

    if (!result.success || !result.data?.[0]?.reviews) {
      throw new Error('Invalid data structure');
    }

    const newReviews = result.data[0].reviews.filter((review) => {
      return !EXCLUDED_REVIEW_IDS.includes(Number(review.id));
    });

    if (newReviews.length < PAGE_LIMIT) {
      hasMore = false;
    } else {
      hasMore = true;
    }

    if (append) {
      if (newReviews.length === 0) {
        hasMore = false;

        const endMsg = document.createElement('div');
        endMsg.className = 'load-more-trigger';
        endMsg.innerText = 'You have reached the end.';
        container.appendChild(endMsg);
      } else {
        allReviewsData = [...allReviewsData, ...newReviews];
        appendGridCards(newReviews);
      }
    } else {
      if (newReviews.length === 0) {
        showErrorOnSkeleton('No reviews found for this category.');
        hasMore = false;
      } else {
        removeSkeletonErrorCard();
        allReviewsData = newReviews;
        renderGridFull(allReviewsData);
      }
    }
  } catch (error) {
    console.error('Fetch error:', error);

    if (append) {
      appendErrorMessage('Failed to load more reviews. Please check your network.', () => {
        if (currentPage > 1) currentPage--;
        loadMore();
      });
    } else {
      showErrorOnSkeleton('Failed to load reviews. Please refresh the page or try again later.');
      hasMore = false;
    }
  } finally {
    isLoading = false;
    scrollThrottle = false;
  }
}

  async function loadMore() {
    if (!hasMore || isLoading) return;
    if (currentType === null) return;
    currentPage++;
    await fetchReviewsByType(currentType, currentPage, true);
  }

  function handleScroll() {
    if (scrollThrottle) return;
    scrollThrottle = true;
    requestAnimationFrame(() => {
      const scrollTop = window.pageYOffset || document.documentElement.scrollTop;
      const windowHeight = window.innerHeight;
      const documentHeight = document.documentElement.scrollHeight;
      if (scrollTop + windowHeight >= documentHeight - 300) {
        if (!isLoading && hasMore) loadMore();
      }
      scrollThrottle = false;
    });
  }

  function renderTabs() {
    const container = document.getElementById('category-tabs');
    if (!dynamicCategories.length) {
      container.innerHTML = `<div class="category-skeleton">${Array(5)
        .fill('<div class="category-skeleton-item"></div>')
        .join('')}</div>`;
      return;
    }
    let html = '';
    for (const cat of dynamicCategories) {
      const activeClass = cat.key === currentCategoryKey ? 'active' : '';
      html += `<div class="category-tab ${activeClass}" data-key="${cat.key}">${escapeHtml(cat.label)}</div>`;
    }
    container.innerHTML = html;
    document.querySelectorAll('.category-tab').forEach((tab) => {
      tab.addEventListener('click', () => {
        const key = tab.getAttribute('data-key');
        if (key === currentCategoryKey) return;
        currentCategoryKey = key;
        const selectedCat = dynamicCategories.find((c) => c.key === key);
        if (selectedCat) {
          window.removeEventListener('scroll', handleScroll);
          currentPage = 1;
          hasMore = true;
          isLoading = false;
          currentType = selectedCat.type;
          allReviewsData = [];
          currentVisibleReviews = [];
          renderTabs();
          fetchReviewsByType(selectedCat.type, 1, false).then(() => {
            window.addEventListener('scroll', handleScroll);
          });
        }
      });
    });
  }

  async function initialize() {
    const initUrl = `${API_BASE}/api/reviews-by-product-type?store=${STORE_NAME}&type=all`;
    try {
      const response = await fetch(initUrl);
      if (!response.ok) throw new Error(`HTTP ${response.status}`);
      const result = await response.json();
      let productTypes = result.product_types;
      if (!productTypes || !Array.isArray(productTypes)) {
        console.warn('API did not return product_types, using fallback');
        productTypes = ['all', 'Prom Dresses', 'Wedding Guest Dresses', 'Mother of the Bride Dresses', 'Other'];
      }
      dynamicCategories = productTypes.map((type) => ({
        key: type,
        label: type === 'all' ? 'View all' : type,
        type: type === 'all' ? 'all' : type,
      }));
      currentCategoryKey = dynamicCategories[0]?.key || 'all';
      renderTabs();
      const defaultType = dynamicCategories.find((c) => c.key === currentCategoryKey)?.type || 'all';
      await fetchReviewsByType(defaultType, 1, false);
      window.addEventListener('scroll', handleScroll);
    } catch (error) {
      console.error('Init error:', error);
      showErrorOnSkeleton('Failed to load reviews. Please refresh the page.');
      hasMore = false;
    }
  }

  const modal = document.getElementById('reviewmyModal');
  const closeBtn = document.querySelector('.myModal-close');
  if (closeBtn)
    closeBtn.onclick = () => {
      modal.style.display = 'none';
    };
  window.onclick = (e) => {
    if (e.target === modal) modal.style.display = 'none';
  };

  function bindModalNav() {
    const prevBtn = document.querySelector('.modal-prev');
    const nextBtn = document.querySelector('.modal-next');

    if (prevBtn) {
      prevBtn.addEventListener('click', () => {
        if (currentModalIndex > 0) {
          currentModalIndex--;
          updateModalContent(currentModalIndex);
        }
      });
    }

    if (nextBtn) {
      nextBtn.addEventListener('click', async () => {
        // 检查是否有下一条评论
        if (currentModalIndex < currentVisibleReviews.length - 3) {
          console.log(currentModalIndex,currentVisibleReviews.length,'cj');
          currentModalIndex++;
          updateModalContent(currentModalIndex);
          return;
        }
        const nextBtnEl = document.querySelector('.modal-next');
        const originalText = nextBtnEl.innerHTML;
        nextBtnEl.innerHTML = 'X';
        nextBtnEl.disabled = true;

        await loadMore();

        // 恢复按钮状态
        nextBtnEl.innerHTML = originalText;
        nextBtnEl.disabled = false;

        // 加载后，检查是否有新数据（currentVisibleReviews 长度是否增加）
        if (currentModalIndex  < currentVisibleReviews.length) {
          // 有新数据，切换到下一个
          currentModalIndex++;
          updateModalContent(currentModalIndex);
        } 
      });
    }
  }

  bindModalNav();
  initialize();
</script>
