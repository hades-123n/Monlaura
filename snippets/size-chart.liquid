    <div class="size-chart-section">
    <!-- INCH Table -->
    <table class="size-table inch-table" id="prodtab-inch-table" style="display:{% if default_unit == 'inch' %}table{% else %}none{% endif %}; width:95%;">
      <thead><tr>{% for header in table_headers %}<th>{{ header }}</th>{% endfor %}</tr></thead>
      <tbody>
        {%- for row in inch_data -%}
          {%- assign cells = row | split: ':' -%}
          {%- assign size_cell = cells[0] -%}
          {%- assign size_parts = size_cell | split: '|' -%}
          {%- if size_parts.size > 1 -%}
            {%- assign size_identifier = size_parts[0] -%}
            {%- assign size_display = size_parts[1] -%}
          {%- else -%}
            {%- assign size_identifier = size_cell -%}
            {%- assign size_display = size_cell -%}
          {%- endif -%}
          <tr data-size="{{ size_identifier }}">
            <td>{{ size_display }}</td>
            {%- for i in (1..cells.size) -%}
              {%- assign idx = forloop.index -%}
              {%- if idx < cells.size -%}
                <td>{{ cells[idx] }}</td>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        {%- endfor -%}
      </tbody>
    </table>

    <!-- CM Table -->
    <table class="size-table cm-table" id="prodtab-cm-table" style="display:{% if default_unit == 'cm' %}table{% else %}none{% endif %}; width:95%;">
      <thead><tr>{% for header in table_headers %}<th>{{ header }}</th>{% endfor %}</tr></thead>
      <tbody>
        {%- for row in cm_data -%}
          {%- assign cells = row | split: ':' -%}
          {%- assign size_cell = cells[0] -%}
          {%- assign size_parts = size_cell | split: '|' -%}
          {%- if size_parts.size > 1 -%}
            {%- assign size_identifier = size_parts[0] -%}
            {%- assign size_display = size_parts[1] -%}
          {%- else -%}
            {%- assign size_identifier = size_cell -%}
            {%- assign size_display = size_cell -%}
          {%- endif -%}
          <tr data-size="{{ size_identifier }}">
            <td>{{ size_display }}</td>
            {%- for i in (1..cells.size) -%}
              {%- assign idx = forloop.index -%}
              {%- if idx < cells.size -%}
                <td>{{ cells[idx] }}</td>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
    </div>
    {%- endif -%}
{%- endif -%}