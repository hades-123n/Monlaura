{% if template.name == 'page' %}
  {%- assign default_unit = 'inch' -%}
  <style>
  .size-chart-section .size-table {
	  width:100%;
	  margin-bottom: 20px;
	  max-width: 600px;
      margin: 0 auto;
  }
  .size-chart-section {
	  width: 100%;
      font-size: 0.9em;
      margin-top: 10px;
      margin-bottom: 10px;
  }
  .size-tabel-before {
	  width: 100%;
	  overflow-x: auto;
	  -webkit-overflow-scrolling: touch;
  }
  .size-chart-header {
    display: flex;
    justify-content: center; 
    font-weight: 700;
    font-size: 1.1em;
    margin-bottom: 10px;
}
.unit-toggle-container {
    font-size: 0.8em;
}
.size-chart-section td, .size-chart-section th {
    border: 1px solid #e6e3e3;
}
  .unit-toggle-container {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: 10px;
    margin-bottom: 20px;
    padding: 15px 0;
  }
  .unit-toggle-label {
    font-weight: 600;
    font-size: 1em;
  }
  .unit-toggle-buttons {
    display: flex;
    gap: 5px;
    border: 1px solid #e6e3e3;
    border-radius: 4px;
    overflow: hidden;
  }
  .unit-toggle-btn {
    padding: 8px 16px;
    background-color: #fff;
    border: none;
    cursor: pointer;
    font-size: 0.9em;
    transition: all 0.3s ease;
    color: #333;
  }
  .unit-toggle-btn:hover {
    background-color: #f5f5f5;
  }
  .unit-toggle-btn.active {
    background-color: #333;
    color: #fff;
  }
  </style>
  
  <div class="unit-toggle-container" id="pagetab-toggle-container">
    <span class="unit-toggle-label">Unit:</span>
    <div class="unit-toggle-buttons">
      <button class="unit-toggle-btn" data-unit="inch" id="pagetab-toggle-inch">IN</button>
      <button class="unit-toggle-btn" data-unit="cm" id="pagetab-toggle-cm">CM</button>
    </div>
  </div>
  
  <script>
  (function() {
    // Unique namespace for page size chart toggle
    var sizeChartPageToggle = {
      // Get saved unit preference or use default
      savedUnit: localStorage.getItem('sizeChartUnit') || 'inch',
      
      // Function to toggle unit display
      toggleUnit: function(unit) {
        // Use specific container to scope the query
        var container = document.getElementById('pagetab-toggle-container');
        if (!container) return;
        
        // Hide all tables within size chart sections
        var inchTables = container.parentElement.querySelectorAll('.inch-table');
        var cmTables = container.parentElement.querySelectorAll('.cm-table');
        
        // Show/hide tables based on selected unit
        if (unit === 'inch') {
          inchTables.forEach(function(table) {
            table.style.display = 'table';
          });
          cmTables.forEach(function(table) {
            table.style.display = 'none';
          });
          // Update button states
          var inchBtn = document.getElementById('pagetab-toggle-inch');
          var cmBtn = document.getElementById('pagetab-toggle-cm');
          if (inchBtn) inchBtn.classList.add('active');
          if (cmBtn) cmBtn.classList.remove('active');
        } else {
          inchTables.forEach(function(table) {
            table.style.display = 'none';
          });
          cmTables.forEach(function(table) {
            table.style.display = 'table';
          });
          // Update button states
          var inchBtn = document.getElementById('pagetab-toggle-inch');
          var cmBtn = document.getElementById('pagetab-toggle-cm');
          if (inchBtn) inchBtn.classList.remove('active');
          if (cmBtn) cmBtn.classList.add('active');
        }
        
        // Save preference
        localStorage.setItem('sizeChartUnit', unit);
      },
      
      // Initialize function
      init: function() {
        var self = this;
        this.toggleUnit(this.savedUnit);
        
        // Add click handlers to toggle buttons
        var inchBtn = document.getElementById('pagetab-toggle-inch');
        var cmBtn = document.getElementById('pagetab-toggle-cm');
        
        if (inchBtn) {
          inchBtn.addEventListener('click', function() {
            self.toggleUnit('inch');
          });
        }
        
        if (cmBtn) {
          cmBtn.addEventListener('click', function() {
            self.toggleUnit('cm');
          });
        }
      }
    };
    
    // Initialize on page load
    if (document.readyState === 'loading') {
      document.addEventListener('DOMContentLoaded', function() {
        sizeChartPageToggle.init();
      });
    } else {
      // DOM already loaded
      sizeChartPageToggle.init();
    }
  })();
  </script>
  {%- comment -%} General Size Table {%- endcomment -%}
  <div class="size-chart-section">
    <div class="size-chart-header">Dress Size (Made to Order)</div>
    <div class="size-tabel-before">
    {%- assign table_headers = general_size-table_headers -%}
    {%- assign inch_data = general_size-inch_data -%}
    {%- assign cm_data = general_size-cm_data -%}
    
    <table class="size-table inch-table" style="display:{% if default_unit == 'inch' %}table{% else %}none{% endif %};">
      <thead><tr>{% for header in table_headers %}<th>{{ header }}</th>{% endfor %}</tr></thead>
      <tbody>
        {%- for row in inch_data -%}
          {%- assign cells = row | split: ':' -%}
          {%- assign size_cell = cells[0] -%}
          {%- assign size_parts = size_cell | split: '|' -%}
          {%- if size_parts.size > 1 -%}
            {%- assign size_identifier = size_parts[0] -%}
            {%- assign size_display = size_parts[1] -%}
          {%- else -%}
            {%- assign size_identifier = size_cell -%}
            {%- assign size_display = size_cell -%}
          {%- endif -%}
          <tr data-size="{{ size_identifier }}">
            <td>{{ size_display }}</td>
            {%- for i in (1..cells.size) -%}
              {%- assign idx = forloop.index -%}
              {%- if idx < cells.size -%}
                <td>{{ cells[idx] }}</td>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
    
    <table class="size-table cm-table" style="display:{% if default_unit == 'cm' %}table{% else %}none{% endif %};">
      <thead><tr>{% for header in table_headers %}<th>{{ header }}</th>{% endfor %}</tr></thead>
      <tbody>
        {%- for row in cm_data -%}
          {%- assign cells = row | split: ':' -%}
          {%- assign size_cell = cells[0] -%}
          {%- assign size_parts = size_cell | split: '|' -%}
          {%- if size_parts.size > 1 -%}
            {%- assign size_identifier = size_parts[0] -%}
            {%- assign size_display = size_parts[1] -%}
          {%- else -%}
            {%- assign size_identifier = size_cell -%}
            {%- assign size_display = size_cell -%}
          {%- endif -%}
          <tr data-size="{{ size_identifier }}">
            <td>{{ size_display }}</td>
            {%- for i in (1..cells.size) -%}
              {%- assign idx = forloop.index -%}
              {%- if idx < cells.size -%}
                <td>{{ cells[idx] }}</td>
              {%- endif -%}
            {%- endfor -%}
          </tr>
        {%- endfor -%}
      </tbody>
    </table>
    </div>
  </div>

